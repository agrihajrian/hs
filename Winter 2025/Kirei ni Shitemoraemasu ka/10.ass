Dialogue: 0,0:00:12.51,0:00:13.21,Default,Girl 1,0,0,0,,Maksudmu apa?
Dialogue: 0,0:00:13.21,0:00:14.07,Default,Girl 2,0,0,0,,Kamu belum dengar?
Dialogue: 0,0:00:14.07,0:00:15.62,Default,Girl 1,0,0,0,,Belum!
Dialogue: 0,0:02:08.04,0:02:13.01,Default,text,0,0,0,,{\fad(481,478)\fs39\shad6\c&H222C04&\3c&HEEDCCF&\blur0\bord3\shad0\\4c&HC7CD96&\pos(1098,927)}Episode{\c&H8065C7&} 10 {\c&H020201}   {\c&HA49F43&}Tantangan {\c&H020201&}Tingkat Tinggi!
Dialogue: 0,0:02:11.30,0:02:13.01,Default - Top,Worker 1,0,0,0,,Oke, oke.
Dialogue: 0,0:02:12.14,0:02:13.01,Default - Top,Worker 2,0,0,0,,Bagus!
Dialogue: 0,0:02:14.61,0:02:18.72,Default,Aji,0,0,0,,Wah, apes banget, ya.
Dialogue: 0,0:02:16.60,0:02:18.07,Default - Top,Worker,0,0,0,,Ya. Bagus, bagus.
Dialogue: 0,0:02:18.72,0:02:20.26,Default,Kinme,0,0,0,,Maaf.
Dialogue: 0,0:02:20.26,0:02:23.41,Default,Kinme,0,0,0,,Bahkan atap terasnya sampai ambruk.
Dialogue: 0,0:02:23.77,0:02:28.27,Default,Aji,0,0,0,,Yah, aku tahu ini bukan salahmu.
Dialogue: 0,0:02:29.65,0:02:33.82,Default,Aji,0,0,0,,Meskipun begitu, biaya perbaikannya\N akan kupotong dari uang sewamu.
Dialogue: 0,0:02:34.85,0:02:36.12,Default,Aji,0,0,0,,Yah...
Dialogue: 0,0:02:36.12,0:02:37.68,Default,Aji,0,0,0,,Bercanda, kok.
Dialogue: 0,0:02:40.41,0:02:43.66,Default,Aji,0,0,0,,Ini. Kerjakan tugasmu.
Dialogue: 0,0:02:43.66,0:02:47.54,Default,Kinme,0,0,0,,Oh, tentu! Akan kuurus ini.
Dialogue: 0,0:02:47.54,0:02:54.39,Default,Aji,0,0,0,,Padahal aku tahu banyak toko lain \Nyang sama murah dan cepatnya dengan tokomu.
Dialogue: 0,0:02:55.55,0:02:56.52,Default,Aji,0,0,0,,Yah...
Dialogue: 0,0:02:56.52,0:02:59.71,Default,Aji,0,0,0,,Cuma bercanda. Bercanda.
Dialogue: 0,0:02:59.71,0:03:02.35,Italics,Kinme (M),0,0,0,,Beliau selalu saja begini.
Dialogue: 0,0:03:05.35,0:03:11.62,Italics,Kinme (M),0,0,0,,Tapi beliau sangat baik menyewakan \Ntoko ini padaku dengan harga murah.
Dialogue: 0,0:03:15.58,0:03:20.07,Default,Yagara,0,0,0,,Maaf, Kinme! Aku benar-benar \Nbutuh bantuanmu.
Dialogue: 0,0:03:20.33,0:03:25.28,Default,Kinme,0,0,0,,Oh, Yagara. Ada apa? \NBukannya kamu harusnya kerja?
Dialogue: 0,0:03:25.28,0:03:26.08,Default,Yagara,0,0,0,,Hah?
Dialogue: 0,0:03:26.08,0:03:27.74,Default,Yagara,0,0,0,,Ada apa dengan tokomu?
Dialogue: 0,0:03:27.74,0:03:29.52,Default,Kinme,0,0,0,,Sebenarnya...
Dialogue: 0,0:03:29.52,0:03:33.84,Default,Kinme,0,0,0,,Waktu badai besar kemarin, \Npohon di belakang tersambar petir.
Dialogue: 0,0:03:33.84,0:03:37.68,Default,Yagara,0,0,0,,Eh? Yang benar? Ngeri sekali!
Dialogue: 0,0:03:37.68,0:03:40.35,Default,Yagara,0,0,0,,Badai waktu itu memang parah, sih.
Dialogue: 0,0:03:40.35,0:03:45.35,Default,Yagara,0,0,0,,Listrik apartemen jelekku sampai mati, \Njadi tak ada yang bisa pakai kamar mandi.
Dialogue: 0,0:03:45.63,0:03:47.88,Default,Kinme,0,0,0,,Pasti merepotkan.
Dialogue: 0,0:03:47.88,0:03:51.98,Default,Kinme,0,0,0,,Anu, jadi kamu mau \Nminta tolong apa, Yagara?
Dialogue: 0,0:03:51.98,0:03:55.82,Default,Yagara,0,0,0,,Oh ya. Coba lihat ini.
Dialogue: 0,0:03:58.36,0:04:01.28,Default,Kinme,0,0,0,,I-Itu kan...
Dialogue: 0,0:04:03.62,0:04:08.12,Default,Yagara,0,0,0,,Yap. Tinta bak. Bodohnya aku sampai kena.
Dialogue: 0,0:04:08.44,0:04:13.00,Default,Yagara,0,0,0,,Sudah kucoba lap pakai tisu, \Ntapi sama sekali tak mempan.
Dialogue: 0,0:04:13.00,0:04:16.54,Default,Kinme,0,0,0,,Oh! Lengan kirimu juga kena.
Dialogue: 0,0:04:16.54,0:04:18.76,Default,Kinme,0,0,0,,Pasti karena bergesekan dengan roknya.
Dialogue: 0,0:04:18.76,0:04:20.30,Default,Yagara,0,0,0,,Hah? Yang benar saja!
Dialogue: 0,0:04:20.30,0:04:22.03,Default,Yagara,0,0,0,,Ampun, deh!
Dialogue: 0,0:04:22.03,0:04:28.27,Default,Yagara,0,0,0,,Hari ini aku lagi sial. \NPadahal baru awal September.
Dialogue: 0,0:04:29.13,0:04:30.27,Default,Kinme,0,0,0,,Ini...
Dialogue: 0,0:04:30.98,0:04:33.96,Default,Kinme,0,0,0,,Sudah berapa lama sejak kena nodanya?
Dialogue: 0,0:04:34.27,0:04:39.94,Default,Yagara,0,0,0,,Hm, coba kuingat. Tadi pagi, \Njadi sekitar tiga jam.
Dialogue: 0,0:04:39.94,0:04:43.61,Default,Kinme,0,0,0,,Hah? Kalau begitu kita harus \Nsegera membersihkannya!
Dialogue: 0,0:04:43.61,0:04:44.66,Default,Yagara,0,0,0,,Hah?
Dialogue: 0,0:04:45.45,0:04:48.79,Default,Kinme,0,0,0,,Membersihkan noda tinta bak itu \Nberpacu dengan waktu!
Dialogue: 0,0:04:49.16,0:04:54.31,Default,Kinme,0,0,0,,Dari pengalamanku, \Nnoda ini lebih parah dari tinta cumi.
Dialogue: 0,0:04:54.31,0:04:56.29,Default,Kinme,0,0,0,,Noda tinta cumi juga susah sih,
Dialogue: 0,0:04:56.29,0:05:00.92,Default,Kinme,0,0,0,,tapi dari semua noda yang ada, \Ntinta bak adalah tantangan tingkat tinggi!
Dialogue: 0,0:05:00.59,0:05:02.05,Default,text,0,0,0,,{\an7\fs45\shad0\pos(222,87)\c&H65626A&\3c&HF4F5F7&\fad(187,1)\}Tinta Bak
Dialogue: 0,0:05:00.59,0:05:02.05,Default,text,0,0,0,,{\an8\fs33\shad0\c&H65626A&\3c&HF4F5F7&\fad(187,1)\pos(300,459)\b1}Kinme
Dialogue: 0,0:05:00.59,0:05:02.05,Default,text,0,0,0,,{\an8\fs33\shad0\c&H65626A&\3c&HF4F5F7&\fad(187,1)\pos(300,642)\b1}Wakana
Dialogue: 0,0:05:00.59,0:05:02.05,Default,text,0,0,0,,{\an8\fs66\shad0\c&H65626A&\3c&HF4F5F7&\fad(187,1)\pos(453,324)\b1\}Tantangan!
Dialogue: 0,0:05:02.05,0:05:04.59,Default,Kinme,0,0,0,,Ada beberapa \Njenis noda berbeda.
Dialogue: 0,0:05:04.59,0:05:06.11,Default,text,0,0,0,,{\\shad0\move(1449,213,1449,-60)\frz21.57\c&H3D485C&\3c&HF6F8F4&}Getah
Dialogue: 0,0:05:04.59,0:05:07.74,Default,text,0,0,0,,{\\shad0\c&H303846&\3c&HE8E1A1&\move(1014,534,1014,-30)\frz0.9001}Larut air
Dialogue: 0,0:05:04.59,0:05:09.16,Default,text,0,0,0,,{\\shad0\c&H1D3F37&\3c&H87F1B0&\move(552,750,552,-60)\frz349.1}Pewarna
Dialogue: 0,0:05:04.59,0:05:09.37,Default,text,0,0,0,,{\\shad0\c&H2E4257&\3c&HD9F9FB&\frz350.2\move(1353,774,1359,-60)}Pemutih
Dialogue: 0,0:05:05.18,0:05:10.85,Default,text,0,0,0,,{\\shad0\c&H303846&\3c&H6FEAF5&\frz0.9001\move(1014,996,1014,0)}Larut minyak
Dialogue: 1,0:05:04.96,0:05:07.10,Default,Yagara,0,0,0,,Ooh, waktunya tambah ilmu!
Dialogue: 1,0:05:07.10,0:05:10.51,Default,Kinme,0,0,0,,Noda bisa dibagi \Nke dalam beberapa kategori utama.
Dialogue: 0,0:05:07.85,0:05:10.85,Default,text,0,0,0,,{\\shad0\c&H31363F&\3c&HBE9CF2&\frz23.14\move(615,1005,615,486,0,2979)}Protein
Dialogue: 0,0:05:08.56,0:05:10.85,Default,text,0,0,0,,{\\shad0\c&H212123&\3c&HD788CE&\frz0.9001\move(1014,1020,1014,615)}Tak larut
Dialogue: 0,0:05:10.85,0:05:14.35,Default,text,0,0,0,,{\\shad0\c&H303846&\3c&HE8E1A1&\an8\fad(1,351)}Larut air
Dialogue: 0,0:05:10.85,0:05:14.35,Default,text,0,0,0,,{\\shad0\c&H2D475D&\3c&HCCEAF5&\an8\fs36\pos(564,618)\fad(1,351)}Alkohol
Dialogue: 0,0:05:10.85,0:05:14.35,Default,text,0,0,0,,{\\shad0\c&H2D475D&\3c&H63A2E4&\an8\fs30\pos(1164,588)\fad(1,351)}Saus
Dialogue: 0,0:05:10.85,0:05:14.35,Default,text,0,0,0,,{\\shad0\c&H0D1E3A&\3c&H6482DE&\an8\fs24\pos(1341,789)\fad(1,351)}Kecap
Dialogue: 1,0:05:10.85,0:05:14.35,Default,Kinme,0,0,0,,Noda yang larut dalam air akan luntur oleh air...
Dialogue: 0,0:05:13.98,0:05:19.32,Default,text,0,0,0,,{\\shad0\c&H303846&\3c&H6FEAF5&\fad(394,1)\an8}Larut minyak
Dialogue: 0,0:05:13.98,0:05:19.32,Default,text,0,0,0,,{\\shad0\c&H141490&\3c&H52926D&\an8\fs27\fad(394,1)\pos(882,684)}Minyak Nabati
Dialogue: 0,0:05:13.98,0:05:19.32,Default,text,0,0,0,,{\\shad0\c&H263C59&\3c&H50DFF5&\an8\fs24\fad(394,1)\pos(1038,717)}Minyak\NWijen
Dialogue: 1,0:05:14.35,0:05:17.36,Default,Kinme,0,0,0,,sedangkan noda larut minyak akan luntur oleh minyak.
Dialogue: 1,0:05:17.36,0:05:19.32,Default,Kinme,0,0,0,,Itu dua jenis utamanya.
Dialogue: 0,0:05:19.70,0:05:24.52,Default,Kinme,0,0,0,,Tapi ada juga noda yang \Ntak mudah luntur oleh air maupun minyak.
Dialogue: 0,0:05:24.52,0:05:29.83,Default,Kinme,0,0,0,,Itu namanya "tak larut", dan \Ncontoh paling terkenalnya adalah tinta bak.
Dialogue: 0,0:05:29.83,0:05:30.87,Default,Yagara,0,0,0,,Oh.
Dialogue: 0,0:05:30.87,0:05:34.72,Default,Kinme,0,0,0,,Noda seperti ini sangat sulit \Ndibersihkan sendiri di rumah.
Dialogue: 0,0:05:34.72,0:05:36.83,Default,Yagara,0,0,0,,Wah, masa sih?
Dialogue: 0,0:05:36.83,0:05:41.71,Default,Kinme,0,0,0,,Dan noda tinta makin sulit dihilangkan \Njika terlalu lama dibiarkan.
Dialogue: 0,0:05:42.23,0:05:46.35,Default,Kinme,0,0,0,,Jadi sebelum mulai, \Naku harus memperingatkanmu
Dialogue: 0,0:05:46.35,0:05:50.27,Default,Kinme,0,0,0,,kalau mungkin aku tak bisa \Nmenghilangkan tintanya sepenuhnya.
Dialogue: 0,0:05:50.27,0:05:53.35,Default,Kinme,0,0,0,,Ada risiko masih \Ntersisa noda tipis.
Dialogue: 0,0:05:53.71,0:05:59.26,Default,Kinme,0,0,0,,Kalau itu terjadi, aku akan kembalikan bajunya \Ndan tak akan memungut biaya cuci.
Dialogue: 0,0:05:59.91,0:06:02.11,Default,Kinme,0,0,0,,Bagaimana menurutmu?
Dialogue: 0,0:06:03.51,0:06:05.36,Default,Yagara,0,0,0,,Bicara apa sih?
Dialogue: 0,0:06:08.37,0:06:10.28,Default,Yagara,0,0,0,,Tentu saja aku mau kamu membersihkannya!
Dialogue: 0,0:06:10.28,0:06:12.28,Default,Kinme,0,0,0,,H-Hah? Hei!
Dialogue: 0,0:06:12.28,0:06:13.33,Default,Yagara,0,0,0,,Hm? Kenapa?
Dialogue: 0,0:06:13.33,0:06:18.54,Default,Kinme,0,0,0,,Eh... jangan lepas bajumu di sini! \NA-Ada orang!
Dialogue: 0,0:06:20.63,0:06:25.16,Default,Yagara,0,0,0,,Ayolah. Santai saja! Lagian aku \Nbawa baju ganti, kok.
Dialogue: 0,0:06:25.16,0:06:27.46,Default,Yagara,0,0,0,,Kamu harus mulai mencucinya \Nsekarang juga, kan?
Dialogue: 0,0:06:27.46,0:06:30.89,Default,Kinme,0,0,0,,Wah! Y-Yagara, hentikan!
Dialogue: 0,0:06:30.89,0:06:34.44,Default,Kinme,0,0,0,,Masuk dan gantilah baju di belakang!
Dialogue: 0,0:06:34.44,0:06:36.13,Default,Yagara,0,0,0,,Yah, kamu yakin?
Dialogue: 0,0:06:38.17,0:06:41.27,Default,Kinme,0,0,0,,Sini, biar kuurus.
Dialogue: 0,0:06:42.61,0:06:45.53,Default,Yagara,0,0,0,,Oke. Lakukan yang terbaik, Kinme.
Dialogue: 0,0:06:45.89,0:06:46.72,Default,Kinme,0,0,0,,Pasti.
Dialogue: 0,0:06:47.45,0:06:49.29,Default,Kinme,0,0,0,,Serahkan saja pada Kinme.
Dialogue: 0,0:07:17.69,0:07:19.43,Default,Worker,0,0,0,,Permisi.
Dialogue: 0,0:07:20.19,0:07:21.72,Default,Kinme,0,0,0,,Ya?
Dialogue: 0,0:07:21.72,0:07:24.03,Default,Worker,0,0,0,,Kami sudah selesai memindahkan pohon tumbangnya.
Dialogue: 0,0:07:24.79,0:07:27.77,Default,Kinme,0,0,0,,Terima kasih banyak. Aku sangat menghargainya.
Dialogue: 0,0:07:27.77,0:07:28.82,Default,Worker,0,0,0,,Sama-sama.
Dialogue: 0,0:07:35.40,0:07:38.77,Italics,Kinme (M),0,0,0,,Sepertinya takkan mempan walau \Ndibersihkan dua atau tiga kali.
Dialogue: 0,0:07:38.77,0:07:41.23,Italics,Kinme (M),0,0,0,,Oh, mungkin aku akan coba itu.
Dialogue: 0,0:07:53.52,0:07:57.26,Italics,Kinme (M),0,0,0,,Tinta bak sangat kebal \Nterhadap bahan kimia.
Dialogue: 0,0:07:57.60,0:08:00.34,Italics,Kinme (M),0,0,0,,Jika aku bisa memakai bahan lain \Nuntuk menyerap sebagian tintanya
Dialogue: 0,0:08:00.73,0:08:02.86,Italics,Kinme (M),0,0,0,,dan melakukannya berulang kali...
Dialogue: 0,0:08:11.17,0:08:12.94,Italics,Kinme (M),0,0,0,,maka sedikit demi sedikit...
Dialogue: 0,0:08:34.27,0:08:36.22,Default,Student,0,0,0,,Sampai jumpa, Bu Guru!
Dialogue: 0,0:08:36.22,0:08:39.35,Default,Yagara,0,0,0,,Ya, sampai jumpa! Hati-hati, ya!
Dialogue: 0,0:08:39.98,0:08:44.11,Default,Yagara,0,0,0,,Jadi tak enak! Aku tak bermaksud \Nmenyuruhmu repot-repot kemari.
Dialogue: 0,0:08:44.11,0:08:47.15,Default,Kinme,0,0,0,,Yah, kamu kan sedang sibuk-sibuknya \Ndengan semester baru.
Dialogue: 0,0:08:47.15,0:08:48.89,Default,Yagara,0,0,0,,Terima kasih.
Dialogue: 0,0:08:48.89,0:08:49.86,Default,Kinme,0,0,0,,Sama sekali tak repot, kok.
Dialogue: 0,0:08:52.05,0:08:54.30,Default,Yagara,0,0,0,,Wah! Hilang semua!
Dialogue: 0,0:08:54.30,0:08:56.87,Default,Yagara,0,0,0,,Luar biasa! Terima kasih!
Dialogue: 0,0:09:00.59,0:09:01.86,Default,Kinme,0,0,0,,Hm...
Dialogue: 0,0:09:02.62,0:09:04.76,Default,Kinme,0,0,0,,Maafkan aku!
Dialogue: 0,0:09:04.76,0:09:05.38,Default,Yagara,0,0,0,,Hah?
Dialogue: 0,0:09:05.38,0:09:09.54,Default,Kinme,0,0,0,,Masih ada noda tipis \Ndi bagian roknya.
Dialogue: 0,0:09:09.54,0:09:12.17,Default,Kinme,0,0,0,,Ini sudah di luar batas kemampuanku.
Dialogue: 0,0:09:12.45,0:09:14.26,Default,Yagara,0,0,0,,Hah? Mana?
Dialogue: 0,0:09:14.59,0:09:16.10,Default,Yagara,0,0,0,,Oh, yang ini?
Dialogue: 0,0:09:16.79,0:09:20.17,Default,Yagara,0,0,0,,Bahkan hampir tak kelihatan! \NTidak masalah kok.
Dialogue: 0,0:09:20.17,0:09:23.68,Default,Yagara,0,0,0,,Jangan khawatir. \NJadi berapa biayanya?
Dialogue: 0,0:09:25.41,0:09:27.53,Default,Kinme,0,0,0,,Aku tak bisa menerima uangmu.
Dialogue: 0,0:09:27.53,0:09:28.27,Default,Yagara,0,0,0,,Hah?
Dialogue: 0,0:09:28.27,0:09:31.61,Default,Kinme,0,0,0,,Aku gagal menjalankan tugasku \Ndan membersihkannya sampai tuntas.
Dialogue: 0,0:09:31.61,0:09:33.76,Default,Kinme,0,0,0,,Oleh karena itu, aku tak bisa menerima bayaran.
Dialogue: 0,0:09:35.58,0:09:39.70,Default,Yagara,0,0,0,,Bicara apa sih? \NAku sangat puas dengan hasil kerjamu.
Dialogue: 0,0:09:39.70,0:09:40.54,Default,Kinme,0,0,0,,Tak bisa.
Dialogue: 0,0:09:40.54,0:09:43.86,Default,Yagara,0,0,0,,Tapi nodanya 99 persen hilang!
Dialogue: 0,0:09:45.92,0:09:47.06,Default,Kinme,0,0,0,,Tetap tak bisa.
Dialogue: 0,0:09:49.43,0:09:51.80,Italics,Yagara (M),0,0,0,,Dia keras kepala sekali.
Dialogue: 0,0:09:52.12,0:09:57.70,Default,Yagara,0,0,0,,Kalau begini bagaimana? Sebagai gantinya \Naku akan bawa makanan enak lain kali. Setuju?
Dialogue: 0,0:09:59.32,0:10:01.35,Default,Kinme,0,0,0,,Terima kasih banyak.
Dialogue: 0,0:10:02.68,0:10:04.84,Default,Nairo,0,0,0,,Bu Guru!
Dialogue: 0,0:10:05.19,0:10:08.06,Default,text,0,0,0,,{\an9\b1\shad0\c&H41474E&\3c&HE9EBF0&}Belalang Sentadu\N{\b0\fs48}Kelas 3-1\N Katakuchi Nairo
Dialogue: 0,0:10:05.19,0:10:08.06,Default,Nairo,0,0,0,,Aku berhasil menulis "belalang sentadu"!
Dialogue: 0,0:10:10.13,0:10:11.64,Default,Nairo,0,0,0,,Coba lihat!
Dialogue: 0,0:10:13.44,0:10:17.07,Default,Nairo,0,0,0,,Oh, ada Kak Kinme! Halo!
Dialogue: 0,0:10:17.07,0:10:21.83,Default,Kinme,0,0,0,,Hah? Tunggu? Yagara, \Napa kamu dan Nairo...
Dialogue: 0,0:10:22.12,0:10:24.08,Default,Nairo,0,0,0,,Dia wali kelasku.
Dialogue: 0,0:10:24.08,0:10:26.21,Default,Yagara,0,0,0,,Dia murid di kelasku.
Dialogue: 0,0:10:26.21,0:10:27.96,Default,Kinme,0,0,0,,Hah?!
Dialogue: 0,0:10:28.34,0:10:33.17,Default,Yagara,0,0,0,,Katakuchi, sudah berapa lembar \Nyang kamu bawa ke Ibu sejak kelas pagi tadi?
Dialogue: 0,0:10:34.55,0:10:35.97,Default,Nairo,0,0,0,,Ini yang kelima!
Dialogue: 0,0:10:35.97,0:10:37.78,Default,Yagara,0,0,0,,Sudah yang kelima?
Dialogue: 0,0:10:37.78,0:10:38.69,Default,Nairo,0,0,0,,Benar sekali.
Dialogue: 0,0:10:38.69,0:10:40.39,Default,Yagara,0,0,0,,Boleh juga kamu, Nak!
Dialogue: 0,0:10:38.97,0:10:43.72,Default - Top,Kinme,0,0,0,,Itu artinya tinta bak \Ndi bajumu itu dari...
Dialogue: 0,0:10:43.72,0:10:47.08,Default,Yagara,0,0,0,,Apa? Bukan, aku yang tumpahkan sendiri.
Dialogue: 0,0:10:47.08,0:10:48.52,Default,Kinme,0,0,0,,Oh.
Dialogue: 0,0:10:50.98,0:10:55.99,Default,text,0,0,0,,{\\shad0\fs66\c&HC4C480&\3c&HFBFFFE&\an7\frz9.132\pos(237,72)}Cuci {\c&0000000&}Sampai Bersih
Dialogue: 0,0:10:55.99,0:11:00.99,Default,text,0,0,0,,{\\shad0\fs66\c&HC4C480&\3c&HFBFFFE&\an7\frz9.132\pos(1257,72)}Cuci {\c&0000000&}Sampai Bersih
Dialogue: 0,0:11:03.49,0:11:06.78,Default,Kinme,0,0,0,,Terima kasih banyak, Hatsuayu!
Dialogue: 0,0:11:06.78,0:11:09.92,Default,Kinme,0,0,0,,Terima kasih ya sudah \Nrepot-repot menjemputku.
Dialogue: 0,0:11:09.92,0:11:12.75,Default,Hatsuayu,0,0,0,,Bukan masalah. Setidaknya ini yang bisa kulakukan.
Dialogue: 0,0:11:12.75,0:11:15.51,Default,Hatsuayu,0,0,0,,Lagi pula aku yang \Nmengajakmu makan siang.
Dialogue: 0,0:11:17.86,0:11:23.39,Default,Kinme,0,0,0,,Senang sekali rasanya bisa melihat rumahmu \Ndan menyantap masakan buatanmu!
Dialogue: 0,0:11:25.25,0:11:28.10,Default,Hatsuayu,0,0,0,,Lagian kamu kan sudah banyak membantuku.
Dialogue: 0,0:11:28.10,0:11:30.90,Default,Hatsuayu,0,0,0,,T-Terutama soal kemampuan sosialku.
Dialogue: 0,0:11:36.65,0:11:41.53,Default,Hatsuayu,0,0,0,,K-Keluargaku yang lain sedang \Nmenghadiri upacara peringatan hari ini,
Dialogue: 0,0:11:41.53,0:11:44.00,Default,Hatsuayu,0,0,0,,jadi cuma aku yang ada di rumah.
Dialogue: 0,0:11:44.00,0:11:47.16,Default,Kinme,0,0,0,,Kamu tidak ikut dengan mereka?
Dialogue: 0,0:11:47.16,0:11:51.42,Default,Hatsuayu,0,0,0,,Eh, iya. Harus ada \Nsetidaknya satu orang yang menjaga rumah.
Dialogue: 0,0:11:54.42,0:12:00.18,Default,Hatsuayu,0,0,0,,Eh... anu. Sebenarnya ada yang \Nlupa kutanyakan padamu.
Dialogue: 0,0:12:00.18,0:12:01.43,Default,Kinme,0,0,0,,Ya?
Dialogue: 0,0:12:01.43,0:12:05.43,Default,Hatsuayu,0,0,0,,K-Keluargaku punya, um...
Dialogue: 0,0:12:16.65,0:12:18.82,Default,Hatsuayu,0,0,0,,H-Hentikan sekarang juga.
Dialogue: 0,0:12:22.70,0:12:24.83,Default,Kinme,0,0,0,,E-Eh...
Dialogue: 0,0:12:24.83,0:12:27.83,Default,Kinme,0,0,0,,U-Uh...
Dialogue: 0,0:12:28.79,0:12:34.24,Default,Hatsuayu,0,0,0,,J-Jangan khawatir. \NKonatsu dan Dai ini jinak, kok.
Dialogue: 0,0:12:34.24,0:12:39.34,Default,Hatsuayu,0,0,0,,K-Kinme, kamu \Ntakut anjing besar tidak?
Dialogue: 0,0:12:39.60,0:12:41.38,Default,Kinme,0,0,0,,Eh, tidak kok.
Dialogue: 0,0:12:41.85,0:12:46.47,Italics,Kinme (M),0,0,0,,Tapi aku gampang berkeringat, \Napa mereka mengendusnya, ya.
Dialogue: 0,0:12:51.48,0:12:55.36,Default,Hatsuayu,0,0,0,,K-Kinme, jam berapa kamu \Nharus kembali bekerja?
Dialogue: 0,0:12:55.36,0:12:59.36,Default,Kinme,0,0,0,,Oh. Jam setengah tiga,\Njadi waktunya masih banyak.
Dialogue: 0,0:12:59.36,0:13:03.86,Default,Hatsuayu,0,0,0,,S-Sebentar lagi matang kok, \Ntunggu sebentar lagi ya.
Dialogue: 0,0:13:03.86,0:13:06.11,Default,Kinme,0,0,0,,O-Oke.
Dialogue: 0,0:13:25.14,0:13:29.00,Default,Kinme,0,0,0,,Wah! Jangan! Jangan... jangan di situ!
Dialogue: 0,0:13:30.14,0:13:33.65,Default,Hatsuayu,0,0,0,,Hah? Kinme, ada apa?
Dialogue: 0,0:13:33.65,0:13:35.36,Default,Kinme,0,0,0,,Tidak apa-apa. Aku baik-baik saja.
Dialogue: 0,0:13:36.40,0:13:39.29,Italics,Kinme (M),0,0,0,,Anjing besar memang menggemaskan.
Dialogue: 0,0:13:40.05,0:13:41.26,Italics,Kinme (M),0,0,0,,Tapi...
Dialogue: 0,0:13:41.65,0:13:46.87,Italics,Kinme (M),0,0,0,,K-Karena tuntutan profesi, mau tak mau \Naku memperhatikan kotoran dan bulu anjing
Dialogue: 0,0:13:47.63,0:13:51.20,Italics,Kinme (M),0,0,0,,di penutup sofa dan karpet ini.
Dialogue: 0,0:13:58.00,0:14:01.92,Default,Hatsuayu,0,0,0,,Terima kasih sudah menunggu. \NSilakan ke sini.
Dialogue: 0,0:14:05.18,0:14:07.43,Default,Kinme,0,0,0,,Wah, cantik sekali!
Dialogue: 0,0:14:07.68,0:14:11.69,Default,Kinme,0,0,0,,Sepertinya aku belum pernah \Nmakan paella asli sebelumnya!
Dialogue: 0,0:14:11.69,0:14:16.68,Default,Hatsuayu,0,0,0,,Yah, ini cuma resep praktis \Npakai penanak nasi, sih.
Dialogue: 0,0:14:16.68,0:14:19.69,Default,Hatsuayu,0,0,0,,Kurasa tak bisa dibilang asli juga.
Dialogue: 0,0:14:19.96,0:14:26.72,Default,Kinme,0,0,0,,Sebenarnya aku sempat agak khawatir \Nkarena kamu tak makan dengan benar.
Dialogue: 0,0:14:26.72,0:14:27.43,Default,Hatsuayu,0,0,0,,Hah?
Dialogue: 0,0:14:28.09,0:14:30.08,Default,Kinme,0,0,0,,Yah, ingat yang di Hatsushima?
Dialogue: 0,0:14:30.08,0:14:32.79,Flashback,Hatsuayu,0,0,0,,Enak sekali!
Dialogue: 0,0:14:32.79,0:14:36.53,Flashback,Hatsuayu,0,0,0,,Sudah lama sekali rasanya sejak \Naku bisa makan makanan seenak ini!
Dialogue: 0,0:14:38.08,0:14:42.14,Flashback Italics,Kinme (M),0,0,0,,Biasanya Hatsuayu makan apa, ya?
Dialogue: 0,0:14:42.50,0:14:46.51,Default,Hatsuayu,0,0,0,,Oh. Maaf sudah membuatmu khawatir.
Dialogue: 0,0:14:46.51,0:14:52.20,Default,Hatsuayu,0,0,0,,Sebenarnya, memasak itu \Nsalah satu hal yang kusukai.
Dialogue: 0,0:14:52.20,0:14:57.02,Default,Hatsuayu,0,0,0,,Tapi belakangan ini aku sibuk sekali, \Njadi jarang masak.
Dialogue: 0,0:14:57.02,0:14:58.98,Default,Kinme,0,0,0,,Syukurlah kalau begitu.
Dialogue: 0,0:15:00.13,0:15:03.03,Default,Kinme,0,0,0,,Kalau begitu, selamat makan.
Dialogue: 0,0:15:07.97,0:15:09.69,Default,Kinme,0,0,0,,Enak!
Dialogue: 0,0:15:13.29,0:15:16.29,Default,Kinme,0,0,0,,Wah. Kita sedang diawasi.
Dialogue: 0,0:15:22.89,0:15:25.25,Default,Kinme,0,0,0,,Carpaccio-nya juga lezat!
Dialogue: 0,0:15:26.27,0:15:30.20,Default,Hatsuayu,0,0,0,,Itu ikan kakap putih yang kubeli \Ndi pasar ikan.
Dialogue: 0,0:15:30.20,0:15:34.34,Default,Kinme,0,0,0,,Oh? Aku juga sering belanja \Ndi pasar ikan lho!
Dialogue: 0,0:15:34.34,0:15:38.44,Default,Hatsuayu,0,0,0,,Hah? Jangan-jangan kita \Npernah berpapasan di sana!
Dialogue: 0,0:15:41.49,0:15:46.82,Default,Hatsuayu,0,0,0,,Aku mau berterima kasih \Nkarena kamu sudah datang, dan... yah,
Dialogue: 0,0:15:47.26,0:15:49.95,Default,Hatsuayu,0,0,0,,sebenarnya untuk setiap hari \Nkita bertemu di pemandian umum.
Dialogue: 0,0:15:49.95,0:15:50.96,Default,Kinme,0,0,0,,Hm?
Dialogue: 0,0:15:51.70,0:15:53.29,Default,Hatsuayu,0,0,0,,Berkat bantuanmu,
Dialogue: 0,0:15:53.29,0:15:58.17,Default,Hatsuayu,0,0,0,,kemampuan sosialku makin membaik, \Njadi masalah kerjaku juga berkurang.
Dialogue: 0,0:15:58.17,0:16:03.21,Default,Hatsuayu,0,0,0,,Kurasa aku mulai bisa lebih \Nmenikmati pekerjaanku sekarang.
Dialogue: 0,0:16:03.84,0:16:07.94,Default,Hatsuayu,0,0,0,,S-Sebenarnya, aku merasa belum pernah...
Dialogue: 0,0:16:08.68,0:16:12.73,Default,Hatsuayu,0,0,0,,mengundang orang asing\N ke rumahku.
Dialogue: 0,0:16:12.73,0:16:14.85,Default,Hatsuayu,0,0,0,,Mungkin ini pertama kalinya.
Dialogue: 0,0:16:16.60,0:16:22.21,Default,Hatsuayu,0,0,0,,Aku selalu menarik diri saat \Nsekolah, dan lebih suka di rumah,
Dialogue: 0,0:16:22.85,0:16:27.78,Default,Hatsuayu,0,0,0,,jadi aku sedikit kaget karena \Nberhasil melakukan ini.
Dialogue: 0,0:16:28.47,0:16:34.87,Default,Hatsuayu,0,0,0,,Kurasa sejak bertemu denganmu, \Naku mulai sedikit berubah.
Dialogue: 0,0:16:35.15,0:16:39.26,Default,Hatsuayu,0,0,0,,Astaga. Aku ngoceh apa sih?
Dialogue: 0,0:16:42.03,0:16:43.13,Default,Kinme,0,0,0,,Uka.
Dialogue: 0,0:16:43.89,0:16:46.00,Default,Kinme,0,0,0,,Kamu salah soal satu hal.
Dialogue: 0,0:16:46.40,0:16:52.21,Default,Kinme,0,0,0,,Kita bukan lagi orang asing. \NKita pasti sudah berteman.
Dialogue: 0,0:16:59.93,0:17:04.28,Default,Kinme,0,0,0,,Terima kasih makanannya! \NMakan siangnya benar-benar lezat.
Dialogue: 0,0:17:04.28,0:17:08.53,Default,Hatsuayu,0,0,0,,Oh, sama-sama. \NYah, akan kuantar kamu kembali.
Dialogue: 0,0:17:10.34,0:17:13.86,Default,Kinme,0,0,0,,Hah? Anjing-anjingnya mana?
Dialogue: 0,0:17:13.86,0:17:14.53,Default,Hatsuayu,0,0,0,,Hah?
Dialogue: 0,0:17:21.80,0:17:24.43,Default,Hatsuayu,0,0,0,,P-Pintu kaca gesernya...
Dialogue: 0,0:17:25.85,0:17:29.60,Default,Hatsuayu,0,0,0,,Aku pasti lupa menguncinya!
Dialogue: 0,0:17:30.05,0:17:35.05,Default,Hatsuayu,0,0,0,,Hei, kalian berdua!\N B-Berhenti main air!
Dialogue: 0,0:17:37.30,0:17:40.56,Default,Hatsuayu,0,0,0,,Ya ampun, kalian jadi berantakan begini!
Dialogue: 0,0:17:40.56,0:17:45.06,Default,Hatsuayu,0,0,0,,Konatsu, Dai, jadilah anjing penurut!
Dialogue: 0,0:17:45.06,0:17:48.57,Default,Hatsuayu,0,0,0,,Hei! Jauhkan kakimu dari rokku!
Dialogue: 0,0:17:52.57,0:17:54.79,Default,Kinme,0,0,0,,Sini kubantu.
Dialogue: 0,0:18:10.37,0:18:13.70,Default,Kinme,0,0,0,,Yah, mau bagaimana lagi?
Dialogue: 0,0:18:53.38,0:18:55.59,Default,Kinme,0,0,0,,Dah! Sampai jumpa lagi!
Dialogue: 0,0:19:01.10,0:19:05.98,Default,Hatsuayu,0,0,0,,Maaf sampai selarut ini.
Dialogue: 0,0:19:06.33,0:19:08.42,Default,Kinme,0,0,0,,Bukan masalah kok.
Dialogue: 0,0:19:08.42,0:19:13.40,Default,Hatsuayu,0,0,0,,Karena sudah lama tak ada \Ntamu yang datang,
Dialogue: 0,0:19:13.40,0:19:15.49,Default,Hatsuayu,0,0,0,,anjingnya jadi agak kelewat semangat.
Dialogue: 0,0:19:16.00,0:19:21.24,Default,Hatsuayu,0,0,0,,Mereka sampai mengotori blusmu.\N Padahal kamu harus kembali kerja.
Dialogue: 0,0:19:21.24,0:19:24.94,Default,Kinme,0,0,0,,Tidak apa-apa. Aku bisa ganti \Ndengan baju yang lain.
Dialogue: 0,0:19:27.12,0:19:33.13,Italics,Kinme (M),0,0,0,,Awalnya agak kaget sih, \Ntapi anjingnya lucu banget!
Dialogue: 0,0:19:33.96,0:19:38.82,Default,Hatsuayu,0,0,0,,Terus soal sarung sofanya, \Nkamu beneran tidak apa-apa?
Dialogue: 0,0:19:38.82,0:19:41.64,Default,Hatsuayu,0,0,0,,Kamu yakin tak mau \Naku bayar sama sekali?
Dialogue: 0,0:19:41.64,0:19:45.36,Default,Kinme,0,0,0,,Kamu sudah memberiku \Nwaktu yang menyenangkan hari ini.
Dialogue: 0,0:19:45.36,0:19:47.43,Default,Kinme,0,0,0,,Anggap saja ini bentuk ucapan terima kasihku.
Dialogue: 0,0:19:47.84,0:19:49.78,Default,Hatsuayu,0,0,0,,Kalau begitu, terima kasih banyak.
Dialogue: 0,0:20:02.97,0:20:07.16,Default,Hatsuayu,0,0,0,,Oke. Sekali lagi terima kasih.
Dialogue: 0,0:20:07.68,0:20:08.54,Default,Kinme,0,0,0,,Sama-sama.
Dialogue: 0,0:20:10.17,0:20:13.54,Default,Hatsuayu,0,0,0,,K-Kira-kira kita bakal ketemu di pemandian.
Dialogue: 0,0:20:13.54,0:20:16.94,Default,Kinme,0,0,0,,Pasti! Makasih ya makan siangnya.
Dialogue: 0,0:20:25.58,0:20:28.95,Default,Kinme,0,0,0,,Oh, Bu Aji! Selamat sore!
Dialogue: 0,0:20:28.95,0:20:29.69,Default,Aji,0,0,0,,Hmph.
Dialogue: 0,0:20:29.97,0:20:31.94,Default,Kinme,0,0,0,,Aku tak sadar Ibu ada di sini.
Dialogue: 0,0:20:31.94,0:20:35.01,Default,Aji,0,0,0,,Aku ke sini mau cek halaman belakang.
Dialogue: 0,0:20:35.01,0:20:39.83,Default,Aji,0,0,0,,Tukang perbaikannya kok lelet sekali. \NApa yang mereka kerjakan sih?
Dialogue: 0,0:20:39.83,0:20:43.07,Default,Aji,0,0,0,,Andai mereka bisa sedikit ngebut \Ndan cepat menyelesaikannya.
Dialogue: 0,0:20:43.07,0:20:49.77,Default,Kinme,0,0,0,,Pasti mereka sibuk keliling kota karena \Nbanyak yang rusak akibat badai kemarin.
Dialogue: 0,0:20:49.77,0:20:50.92,Default,Aji,0,0,0,,Hmph.
Dialogue: 0,0:20:56.72,0:20:59.54,Default,Aji,0,0,0,,Benda apa itu?
Dialogue: 0,0:20:59.84,0:21:03.59,Default,Kinme,0,0,0,,Oh. Itu jejak kaki anjing.
Dialogue: 0,0:21:03.92,0:21:08.38,Default,Aji,0,0,0,,Astaga! Jadi kamu habiskan jam istirahatmu \Nuntuk bermain dengan anjing?
Dialogue: 0,0:21:09.85,0:21:13.08,Default,Aji,0,0,0,,Bisa-bisa kalau aku menitipkan \Ncucianku padamu,
Dialogue: 0,0:21:13.08,0:21:17.32,Default,Aji,0,0,0,,semuanya akan kembali \Ndengan stempel jejak kaki di atasnya.
Dialogue: 0,0:21:17.32,0:21:20.15,Italics,Kinme (M),0,0,0,,Selalu saja begitu.
Dialogue: 0,0:21:20.15,0:21:21.40,Default,Aji,0,0,0,,Ya...
Dialogue: 0,0:21:21.40,0:21:23.05,Default,Aji,0,0,0,,Bercanda, kok.
Dialogue: 0,0:21:23.71,0:21:26.85,Default,Aji,0,0,0,,Nah, urusanku sudah selesai, jadi aku pamit.
Dialogue: 0,0:21:27.88,0:21:29.89,Italics,Kinme (M),0,0,0,,Dia berusaha menutupinya,
Dialogue: 0,0:21:29.89,0:21:33.28,Italics,Kinme (M),0,0,0,,tapi dia sangat mengkhawatirkanku \Nsampai datang mengecek toko ini.
Dialogue: 0,0:21:35.48,0:21:39.38,Default,Regular 1,0,0,0,,Ini sudah lewat jam setengah tiga. \NBisa tidak?
Dialogue: 0,0:21:39.64,0:21:41.01,Default,Kinme,0,0,0,,Oh! Tentu saja!
Dialogue: 0,0:21:41.46,0:21:44.86,Default,Kinme,0,0,0,,A-Aku harus ganti baju dulu, \Njadi tolong beri aku waktu sebentar.
