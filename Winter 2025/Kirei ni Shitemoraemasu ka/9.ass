Dialogue: 1,0:12:36.78,0:12:39.53,Default,text,0,0,0,,{\fs39\shad0\c&H8B9299&\3c&HA7F9FF&\an7\bord6\frz10.28\pos(900,936)}Nanti aku telepon
Dialogue: 1,0:12:37.23,0:12:38.86,Italics,Kyusho (M),0,0,0,,Hah? Telepon?
Dialogue: 0,0:12:42.32,0:12:43.68,Default,Kyusho,0,0,0,,Halo?
Dialogue: 0,0:12:44.25,0:12:45.12,Default,Kyusho,0,0,0,,Ya.
Dialogue: 0,0:12:46.02,0:12:47.54,Default,Kyusho,0,0,0,,Ya, kami baik-baik saja.
Dialogue: 0,0:12:48.28,0:12:49.36,Default,Kyusho,0,0,0,,Dan di sana?
Dialogue: 0,0:12:49.92,0:12:51.46,Default,Kyusho,0,0,0,,Syukurlah kalau begitu.
Dialogue: 0,0:12:52.27,0:12:54.48,Default,Kyusho,0,0,0,,Hah? Ibu mau bicara dengan Kinme-san?
Dialogue: 0,0:12:55.67,0:12:57.92,Default,Kyusho,0,0,0,,Ibu bilang mau bicara.
Dialogue: 0,0:12:57.92,0:12:59.93,Default,Kinme,0,0,0,,Hah? Denganku?
Dialogue: 0,0:13:00.20,0:13:04.16,Default,Kinme,0,0,0,,Halo, Ishimochi-san? Selamat malam.
Dialogue: 0,0:13:04.63,0:13:08.07,Default,Kinme,0,0,0,,Eh... Tidak, tak merepotkan.
Dialogue: 0,0:13:08.58,0:13:12.71,Default,Kinme,0,0,0,,Sama sekali tidak. Justru,\Naku yang harus minta maaf.
Dialogue: 0,0:13:12.71,0:13:14.94,Default,Kinme,0,0,0,,Hah? Oh, begitu.
Dialogue: 0,0:13:15.26,0:13:17.69,Default,Ishimochi,0,0,0,,Maafkan aku ya, Kinme-san.
Dialogue: 0,0:13:17.69,0:13:22.20,Default,Ishimochi,0,0,0,,Biar aku jemput Kyu pakai mobil.\NTapi mungkin agak telat.
Dialogue: 0,0:13:22.20,0:13:24.69,Default,Kinme,0,0,0,,Itu terlalu bahaya, Ishimochi-san.
Dialogue: 0,0:13:24.69,0:13:27.20,Default,Kinme,0,0,0,,Jangan keluar rumah,\Nmeskipun naik mobil.
Dialogue: 0,0:13:27.20,0:13:31.65,Default,Kinme,0,0,0,,Hujan dan anginnya sangat kencang,\ndan kita tak tahu kapan akan berhenti.
Dialogue: 0,0:13:31.65,0:13:35.96,Italics,Ishimochi,0,0,0,,Aku tahu, tapi cepat atau lambat\naku harus menjemputnya.
Dialogue: 0,0:13:36.82,0:13:39.61,Default,Kinme,0,0,0,,Kalau begitu, mungkin aku
Dialogue: 0,0:13:40.02,0:13:42.72,Default,Kinme,0,0,0,,biarkan Kyusho-kun menginap di sini saja.
Dialogue: 0,0:13:42.72,0:13:43.16,Default,Kyusho,0,0,0,,Eh?
Dialogue: 0,0:13:43.16,0:13:46.64,Default,Kinme,0,0,0,,Tidak apa-apa kok!\NTolong jangan khawatir.
Dialogue: 0,0:13:46.97,0:13:48.79,Default,Kinme,0,0,0,,Baiklah. Selamat malam.
Dialogue: 0,0:13:48.79,0:13:50.98,Default,Kyusho,0,0,0,,Uh, aku rasa tak seharusnya...
Dialogue: 0,0:13:51.30,0:13:54.00,Default,Kinme,0,0,0,,Tak apa! Jangan khawatir.
Dialogue: 0,0:13:54.48,0:13:55.55,Default,Kinme,0,0,0,,Ini.
Dialogue: 0,0:13:58.73,0:14:02.06,Default,Kinme,0,0,0,,Tak apa-apa! Tak perlu cemas.
Dialogue: 0,0:14:02.06,0:14:05.60,Default,Kinme,0,0,0,,Akan kusiapkan agar kita bisa\ntidur di kamar terpisah.
Dialogue: 0,0:14:05.60,0:14:08.74,Default,Kinme,0,0,0,,Lagipula, ruang penyimpanan\ndi lantai dua sedang kosong.
Dialogue: 0,0:14:08.74,0:14:10.54,Default,Kyusho,0,0,0,,I-Iya.
Dialogue: 0,0:14:11.02,0:14:13.75,Default,Kyusho,0,0,0,,Tapi kau sudah banyak repot...
Dialogue: 0,0:14:15.25,0:14:20.44,Default,Kinme,0,0,0,,Semuanya beres. Anggap saja\Nkita saling membantu, jadi tak apa.
Dialogue: 0,0:14:21.37,0:14:24.02,Italics,Kinme (M),0,0,0,,Aku tak bisa bergantung pada Kyusho-kun terus.
Dialogue: 0,0:14:24.02,0:14:26.13,Italics,Kinme (M),0,0,0,,Aku harus tunjukkan kalau aku juga bisa diandalkan!
Dialogue: 0,0:14:36.30,0:14:40.04,Default,Kinme,0,0,0,,Tapi kenapa listriknya\nbelum nyala juga ya?
Dialogue: 0,0:14:40.48,0:14:42.15,Default,Kyusho,0,0,0,,Sudah lumayan lama.
Dialogue: 0,0:14:42.15,0:14:47.99,Italics,Kinme (M),0,0,0,,Aku merasa tak tenang membiarkan\ncucian itu tak selesai semalaman.
Dialogue: 0,0:14:47.99,0:14:51.66,Italics,Kinme (M),0,0,0,,Bagaimana ini? Cuci pakai tangan saja?
Dialogue: 0,0:14:57.67,0:14:59.80,Default,Kyusho,0,0,0,,Akhirnya nyala juga.
Dialogue: 0,0:15:01.29,0:15:03.01,Default,Kinme,0,0,0,,Kyusho-kun...
Dialogue: 0,0:15:03.01,0:15:03.67,Default,Kyusho,0,0,0,,Ya?
Dialogue: 0,0:15:04.28,0:15:07.97,Default,Kinme,0,0,0,,Maaf, tapi aku harus\nsegera lanjut kerja!
Dialogue: 0,0:15:07.97,0:15:08.81,Default,Kyusho,0,0,0,,Hah?
Dialogue: 0,0:15:09.30,0:15:11.81,Default,Kinme,0,0,0,,Silakan bersantai\ndan anggap rumah sendiri.
Dialogue: 0,0:15:16.21,0:15:18.43,Default,Kyusho,0,0,0,,Kinme-san memang rajin.
Dialogue: 0,0:15:38.35,0:15:38.82,Default,text,0,0,0,,{\shad0\b1\c&H555152&\3c&HE7E8E9&\pos(963,384)\fs90}Mulai
Dialogue: 0,0:15:38.35,0:15:38.69,Default,text,0,0,0,,{\shad0\b1\c&H555152&\3c&HE7E8E9&\fs90\pos(969,789)}Jeda
Dialogue: 0,0:16:18.75,0:16:20.92,Default,Kinme,0,0,0,,Ini di sini...
Dialogue: 0,0:16:22.67,0:16:24.00,Default,Kinme,0,0,0,,dan ini di sini.
Dialogue: 0,0:16:29.70,0:16:31.68,Default,Kinme,0,0,0,,Sudah beres semua.
Dialogue: 0,0:16:32.76,0:16:33.84,Default,Kyusho,0,0,0,,Iya.
Dialogue: 0,0:16:34.51,0:16:36.90,Default,Kinme,0,0,0,,Terima kasih banyak atas bantuanmu.
Dialogue: 0,0:16:36.90,0:16:38.05,Default,Kyusho,0,0,0,,Sama-sama.
Dialogue: 0,0:16:43.48,0:16:48.46,Default,Kinme,0,0,0,,Pancurannya sudah bisa dipakai,\Nsilakan mandi dulu.
Dialogue: 0,0:16:48.46,0:16:51.82,Default,Kinme,0,0,0,,Biar aku bisa siapkan\nfuton untukmu.
Dialogue: 0,0:16:51.82,0:16:54.29,Default,Kyusho,0,0,0,,Ah, terima kasih.
Dialogue: 0,0:16:57.25,0:17:01.16,Italics,Kinme (M),0,0,0,,Aku harus mengecek\nhalaman belakang besok.
Dialogue: 0,0:17:08.50,0:17:09.18,Default,Kinme,0,0,0,,Eh?
Dialogue: 0,0:17:14.88,0:17:19.76,Default,Kyusho,0,0,0,,Pohon itu tumbang menembus\natap teras.
Dialogue: 0,0:17:21.71,0:17:24.52,Default,Kyusho,0,0,0,,Ah, aku sudah selesai, giliranmu.
Dialogue: 0,0:17:25.57,0:17:26.57,Default,Kyusho,0,0,0,,Kinme-san?
Dialogue: 0,0:17:27.91,0:17:28.72,Default,Kyusho,0,0,0,,Eh?
Dialogue: 0,0:17:29.44,0:17:31.05,Default,Kinme,0,0,0,,Kyusho-kun...
Dialogue: 0,0:17:32.34,0:17:34.30,Default,Kinme,0,0,0,,Aku benar-benar minta maaf!
Dialogue: 0,0:17:34.30,0:17:38.29,Default,Kinme,0,0,0,,Anu, kamu tak keberatan tidur sekamar sama aku?
Dialogue: 0,0:17:38.58,0:17:40.53,Default,Kyusho,0,0,0,,Tadi bilang ada kamar kosong?
Dialogue: 0,0:17:40.53,0:17:45.92,Default,Kinme,0,0,0,,Karena cuciannya sudah selesai,\naku pakai kamarnya untuk jemur pakaian.
Dialogue: 0,0:17:46.54,0:17:49.10,Default,Kinme,0,0,0,,Aku benar-benar minta maaf!
Dialogue: 0,0:17:49.10,0:17:52.56,Default,Kinme,0,0,0,,Kalau kamu tidak mau,\naku bisa tidur di lorong.
Dialogue: 0,0:17:52.56,0:17:55.30,Default,Kyusho,0,0,0,,Tidak, aku tak bisa... membiarkanmu begitu...
Dialogue: 0,0:17:56.51,0:18:00.18,Default,Kyusho,0,0,0,,Kalau kau tak keberatan, aku juga tidak...
Dialogue: 0,0:18:00.18,0:18:03.41,Default,Kinme,0,0,0,,Terima kasih!
Dialogue: 0,0:18:03.41,0:18:04.69,Italics,Kyusho (M),0,0,0,,Astaga.
Dialogue: 0,0:18:05.97,0:18:08.79,Default,Kinme,0,0,0,,Kalau begitu aku mau mandi juga.
Dialogue: 0,0:18:28.96,0:18:32.50,Italics,Kyusho (M),0,0,0,,Oh ya, terakhir kali aku di kamar ini
Dialogue: 0,0:18:41.68,0:18:43.47,Italics,Kyusho (M),0,0,0,,adalah saat hari itu terjadi.
Dialogue: 0,0:18:50.62,0:18:53.57,Default,Kinme,0,0,0,,Maaf. Apa aku membangunkanmu?
Dialogue: 0,0:18:54.95,0:18:58.38,Default,Kyusho,0,0,0,,Tidak apa-apa. Aku belum tidur.
Dialogue: 0,0:19:08.09,0:19:10.96,Default,Kinme,0,0,0,,Baiklah, selamat malam.
Dialogue: 0,0:19:11.56,0:19:13.00,Default,Kyusho,0,0,0,,Selamat malam.
Dialogue: 0,0:19:23.35,0:19:26.35,Default,Kinme,0,0,0,,Masih terdengar suara gemuruh\ndi kejauhan.
Dialogue: 0,0:19:26.83,0:19:28.20,Default,Kyusho,0,0,0,,Sepertinya begitu.
Dialogue: 0,0:19:28.86,0:19:34.21,Default,Kinme,0,0,0,,Tapi kalau sejauh itu,\nsepertinya aku takkan takut.
Dialogue: 0,0:19:36.24,0:19:39.71,Default,Kinme,0,0,0,,Tadi saat mandi,
Dialogue: 0,0:19:39.71,0:19:44.62,Default,Kinme,0,0,0,,aku memikirkan apa yang\Nmembuatku begitu takut pada petir.
Dialogue: 0,0:19:46.86,0:19:48.97,Default,Kinme,0,0,0,,Kira-kira apa penyebabnya.
Dialogue: 0,0:19:54.42,0:20:01.36,Default,Kinme,0,0,0,,Sebenarnya, aku tak tahu pasti apakah aku\npernah ke Hatsushima atau tidak.
Dialogue: 0,0:20:02.16,0:20:08.44,Default,Kinme,0,0,0,,{\t(5963,6255,\1c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Orang yang pergi bersamaku bilang\nsepertinya aku tenggelam dalam ingatan di sana.
Dialogue: 0,0:20:10.44,0:20:17.52,Default,Kinme,0,0,0,,Terkadang ingatan yang belum lama,\ningatan dari dua tahun terakhir,
Dialogue: 0,0:20:17.52,0:20:19.45,Default,Kinme,0,0,0,,tiba-tiba menghilang begitu saja.
Dialogue: 0,0:20:21.95,0:20:25.53,Default,Kinme,0,0,0,,Rasanya seperti ada seseorang yang bukan aku
Dialogue: 0,0:20:25.53,0:20:29.02,Default,Kinme,0,0,0,,melakukan hal-hal yang tak kusadari\nsaat aku lengah.
Dialogue: 0,0:20:30.94,0:20:36.46,Default,Kinme,0,0,0,,Tapi sepertinya tak ada\nyang bisa kulakukan.
Dialogue: 0,0:20:40.54,0:20:45.22,Default,Kyusho,0,0,0,,Kalau kau sampai melupakan\naku, Kuriru, dan Moruda,
Dialogue: 0,0:20:46.23,0:20:47.64,Default,Kyusho,0,0,0,,mungkin akan...
Dialogue: 0,0:21:32.38,0:21:35.52,Default,Ishimochi,0,0,0,,Terima kasih! Maaf sudah merepotkan.
Dialogue: 0,0:21:35.52,0:21:41.03,Default,Kinme,0,0,0,,Tidak apa-apa! Dia justru banyak\nmembantuku di toko.
Dialogue: 0,0:21:41.03,0:21:43.53,Default,Ishimochi,0,0,0,,Kyu bisa membantu juga?
Dialogue: 0,0:21:43.53,0:21:45.46,Default,Kinme,0,0,0,,Tentu saja!
Dialogue: 0,0:21:45.93,0:21:48.66,Default,Kinme,0,0,0,,Kyusho-kun, terima kasih atas bantuanmu.
Dialogue: 0,0:21:53.17,0:21:56.92,Default,Ishimochi,0,0,0,,Wah, Kyu! Kerja bagus. \NHebat juga kamu!
Dialogue: 0,0:21:57.43,0:21:58.42,Default,Kinme,0,0,0,,Ah!
Dialogue: 0,0:21:58.42,0:22:01.40,Default,Kinme,0,0,0,,Kyusho-kun! Tasmu, tasmu!
Dialogue: 0,0:23:34.93,0:23:39.94,Default,text,0,0,0,,{\shad0\c&H020201&\bord0\pos(720,465)}Episode {\c&H8A80CC&}10{\c&H020201}  Tantangan {\c&HA49F43&}Kelas Atas!{\c&H020201&}
Dialogue: 0,0:23:35.79,0:23:39.24,Default,Kinme,0,0,0,,Selanjutnya "Tantangan Kelas Atas!"
