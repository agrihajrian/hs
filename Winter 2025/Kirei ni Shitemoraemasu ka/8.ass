Dialogue: 0,0:01:31.53,0:01:36.49,Default,text,0,0,0,,{\fad(481,478)\fs17.333\shad2.667\c&H222C04&\3c&HEEDCCF&\blur0\bord1.333\shad0\fnTimes New Roman\4c&HC7CD96&\pos(162.975,84)}Episode{\c&H8065C7&} 8 {\c&H8A80CC&}{\c&H020201}    Tadi Itu Benar-benar {\c&HA49F43&}Hebat
Dialogue: 0,0:01:34.37,0:01:37.74,Default,text,0,0,0,,{\shad0\fs37.333\an8\\b1\c&H82732B&\3c&HE2F3F4&\pos(437.25,26.667)}Pemandian Besar
Dialogue: 0,0:01:43.76,0:01:49.71,Italics,Kinme (M),0,0,0,,Lonjakan pesanan daring langsung surut\Nsetelah seminggu berlalu.
Dialogue: 0,0:01:50.03,0:01:53.76,Italics,Kinme (M),0,0,0,,Apa itu cuma\Ntren sesaat, ya?
Dialogue: 0,0:01:58.47,0:02:02.10,Italics,Kinme (M),0,0,0,,Dingin banget! Dan manis.
Dialogue: 0,0:02:02.83,0:02:05.98,Italics,Kinme (M),0,0,0,,Ruang tunggunya juga luas!
Dialogue: 0,0:02:06.55,0:02:09.97,Italics,Kinme (M),0,0,0,,Sesekali mencoba pemandian umum\Nlain memang seru.
Dialogue: 0,0:02:11.00,0:02:16.24,Default,Hatsuayu,0,0,0,,Ma-Maaf, Aku terlambat.
Dialogue: 0,0:02:18.24,0:02:22.52,Default,Staff 1,0,0,0,,Kan sudah dibilang kita harus\Nsurvei lokasi pagi-pagi sekali.
Dialogue: 0,0:02:22.52,0:02:26.13,Default,Staff 1,0,0,0,,Besok pagi kita sudah\Nharus sampai di Shikoku.
Dialogue: 0,0:02:26.13,0:02:32.40,Default,Hatsuayu,0,0,0,,I-Itu kesalahanku.\NAku benar-benar minta maaf.
Dialogue: 0,0:02:32.65,0:02:39.22,Default,Hatsuayu,0,0,0,,Tempatnya segera tutup, jadi\Nmohon tunggu sebentar lagi.
Dialogue: 0,0:02:39.22,0:02:42.94,Default,Staff 1,0,0,0,,Koordinator kota sebelumnya\Njauh lebih andal.
Dialogue: 0,0:02:42.94,0:02:45.39,Default,Hatsuayu,0,0,0,,Mohon maaf sebesar-besarnya.
Dialogue: 0,0:02:51.90,0:02:53.36,Default,Staff 2,0,0,0,,Apa waktunya akan cukup?
Dialogue: 0,0:02:53.36,0:02:55.51,Default,Staff 1,0,0,0,,Yah, harus dicukup-cukupkan.
Dialogue: 0,0:02:54.49,0:02:56.56,Default,Customer,0,0,0,,{\an8}Airnya segar sekali!
Dialogue: 0,0:02:56.56,0:02:58.16,Default,Manager,0,0,0,,Terima kasih banyak.
Dialogue: 0,0:03:02.17,0:03:04.52,Default,Staff 1,0,0,0,,Hei! Kopinya tumpah ke bajuku!
Dialogue: 0,0:03:04.91,0:03:10.00,Default,Hatsuayu,0,0,0,,Ma-Maaf! Aku melamun.
Dialogue: 0,0:03:10.00,0:03:12.42,Default,Hatsuayu,0,0,0,,Akan segera dilap.
Dialogue: 0,0:03:12.42,0:03:15.67,Default,Kinme,0,0,0,,Anu, jangan dilap!
Dialogue: 0,0:03:15.67,0:03:16.58,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 0,0:03:16.58,0:03:19.26,Default,Kinme,0,0,0,,Aku ambilkan sesuatu dulu.\NTolong tunggu sebentar.
Dialogue: 0,0:03:20.89,0:03:21.93,Default,Staff 1,0,0,0,,Siapa itu tadi?
Dialogue: 0,0:03:24.43,0:03:27.52,Default,Kinme,0,0,0,,Kalau kopi tumpah, jangan panik.
Dialogue: 0,0:03:27.52,0:03:31.82,Default,Kinme,0,0,0,,Basahi tisu dengan air sabun,\Nsetelah noda dibasahi,
Dialogue: 0,0:03:32.44,0:03:36.20,Default,Kinme,0,0,0,,letakkan handuk atau sapu tangan\Ndi bawah noda,
Dialogue: 0,0:03:36.20,0:03:41.82,Default,Kinme,0,0,0,,lalu tekan dari atas dengan tisu\Nkering untuk menyerap cairannya.
Dialogue: 0,0:03:41.82,0:03:43.58,Default,Kinme,0,0,0,,Nodanya pasti akan hilang.
Dialogue: 0,0:03:43.58,0:03:49.70,Default,Kinme,0,0,0,,Kalau panik dan malah digosok,\Nnodanya akan membekas, jadi hati-hati.
Dialogue: 0,0:03:51.09,0:03:52.75,Default,Staff 1,0,0,0,,I-Iya.
Dialogue: 0,0:03:53.71,0:03:57.47,Default,Kinme,0,0,0,,Nah. bajumu sudah aman sekarang.
Dialogue: 0,0:03:57.47,0:03:59.09,Default,Staff 1,0,0,0,,Te-Terima kasih banyak.
Dialogue: 0,0:03:59.09,0:04:02.35,Default,Hatsuayu,0,0,0,,E-Etto...
Dialogue: 0,0:04:02.74,0:04:07.98,Default,Kinme,0,0,0,,Aku pengelola laundry di dekat sini.\NNamaku Kinme.
Dialogue: 0,0:04:08.26,0:04:10.48,Default,Kinme,0,0,0,,Sudah biasa menangani hal seperti ini.
Dialogue: 0,0:04:11.30,0:04:16.24,Default,Hatsuayu,0,0,0,,I-Itu tadi luar biasa sekali!
Dialogue: 0,0:04:16.59,0:04:21.07,Default,Hatsuayu,0,0,0,,Aku juga ingin bisa sigap\Nseperti itu.
Dialogue: 0,0:04:21.07,0:04:23.37,Default,Kinme,0,0,0,,E-Etto...
Dialogue: 0,0:04:25.98,0:04:27.92,Default,Hatsuayu,0,0,0,,Aku lupa memperkenalkan diri.
Dialogue: 0,0:04:27.92,0:04:33.87,Default,Hatsuayu,0,0,0,,Aku bekerja di balai kota\Ndi Bagian Ekonomi Pariwisata.
Dialogue: 0,0:04:33.87,0:04:35.88,Default,Hatsuayu,0,0,0,,Nama Hatusayu Uka.
Dialogue: 0,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\p1\bord0\an8\shad0\c&HF1F1F3&\frz6.079\pos(522.712,98.667)\fscx121\fscy78\clip(m 606.875 310.625 l 617.5 304 628 302.625 645.25 305.375 658.5 310.625 726.125 300 702.25 82.625 349.75 110.625 369.625 334.625)}m 0 0 l 304.75 0 l 304.75 286.625 l 0 286.625
Dialogue: 1,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\an9\shad0\\b1\frz5.172\c&H6D6B70&\3c&HF1F2F4&\pos(605.525,101.333)}Balai Kota Atami
Dialogue: 1,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\an7\shad0\fnTimes New Roman\frz5.172\c&H6D6B70&\3c&HF1F2F4&\fs21.333\pos(360.4,170.667)}Bagian Ekonomi Pariwisata,\NDepartemen Pariwisata dan Konstruksi\NKantor Promosi Pariwisata
Dialogue: 1,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\an9\shad0\\b1\frz5.172\c&H6D6B70&\3c&HF1F2F4&\fs18.667\pos(683.7,216)}Koordinasi dan Bantuan Lokasi
Dialogue: 1,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\an9\shad0\\b1\frz5.172\c&H6D6B70&\3c&HF1F2F4&\fs40\pos(659.85,248)}Hatsuayu Uka
Dialogue: 0,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\p1\bord0\an8\shad0\c&HE9EDEF&\frz6.079\fscx122\fscy23\pos(382.262,346.667)\clip(m 231.875 365.375 l 229.25 378.625 226.625 392 221.25 405.375 217.25 413.375 213.375 420 515.375 392 506.125 354.625 503.5 342.625)}m 0 0 l 304.75 0 l 304.75 286.625 l 0 286.625
Dialogue: 1,0:04:38.88,0:04:41.39,Default,text,0,0,0,,{\an7\shad0\fnTimes New Roman\frz5.172\c&H6D6B70&\3c&HF1F2F4&\fs21.333\pos(237.175,384)}1-1 Chuo-cho, Atami, Shizuoka
Dialogue: 0,0:04:38.88,0:04:40.46,Default,Kinme,0,0,0,,Koordinator lokasi?
Dialogue: 0,0:04:40.46,0:04:41.39,Default,Hatsuayu,0,0,0,,Benar.
Dialogue: 0,0:04:41.66,0:04:46.27,Default,Hatsuayu,0,0,0,,Aku memberi info soal\Nfasilitas lokasi untuk TV dan film,
Dialogue: 0,0:04:46.27,0:04:48.80,Default,Hatsuayu,0,0,0,,serta membantu koordinasi syuting.
Dialogue: 0,0:04:50.14,0:04:53.40,Default,Staff 1,0,0,0,,Katanya sudah boleh masuk, ayo cepat.
Dialogue: 0,0:04:53.40,0:04:54.56,Default,Hatsuayu,0,0,0,,I-Iya.
Dialogue: 0,0:04:56.11,0:04:59.56,Default,Hatsuayu,0,0,0,,Terima kasih banyak. Permisi.
Dialogue: 0,0:05:02.31,0:05:06.71,Italics,Kinme (M),0,0,0,,Bekerja sampai selarut ini?\NTugas yang berat, ya.
Dialogue: 0,0:05:13.34,0:05:17.08,Default,Kinme,0,0,0,,Iya. Aku bisa mengurus bahan ini.
Dialogue: 0,0:05:17.08,0:05:20.61,Default,Regular,0,0,0,,Benarkah? Syukurlah!\NKau kupercayakan untuk ini.
Dialogue: 0,0:05:20.61,0:05:21.78,Default,Kinme,0,0,0,,Tentu!
Dialogue: 0,0:05:21.78,0:05:23.52,Default,Kinme,0,0,0,,Andalkan saja Kinme!
Dialogue: 0,0:05:23.52,0:05:25.72,Default,Regular,0,0,0,,Kamu memang selalu bisa diandalkan.
Dialogue: 0,0:05:52.96,0:05:55.46,Default,text,0,0,0,,{\an7\b1\c&HE6DDDC&\3c&H9A501C&\shad0\fax0.26\fs40\frz350.7\pos(86.125,202.667)}Toko Suvenir\N{\an7\b1\c&HE6DDDC&\3c&H9A501C&\shad0\fax0.26\b1\3c&H9A501C&\fs32\shad0\pos(153.7,253.333)}\hToko Ikan Kering Atsuei
Dialogue: 0,0:05:55.46,0:06:01.97,Default,text,0,0,0,,{\an7\fs21.333\b1\shad0\c&H464039&\3c&HA0A19C&\pos(18.55,21.333)\frz355.5}Penjualan Langsung Ikan Kering Atsuei
Dialogue: 0,0:05:55.46,0:06:01.97,Default,text,0,0,0,,{\an7\fs18.667\b1\shad0\c&H464039&\3c&HA0A19C&\pos(598.9,72)\frz356.1}Toko Hadiah dan Suvenir Atsuei
Dialogue: 0,0:05:55.78,0:05:59.70,Default,Kinme,0,0,0,,Oh, benar. Aku sudah pernah ke pemandian itu.
Dialogue: 0,0:05:59.70,0:06:01.97,Default,Kinme,0,0,0,,Agak jauh, tapi sangat bagus.
Dialogue: 0,0:06:01.97,0:06:06.47,Default,Nairo's Grandma,0,0,0,,Begitukah? Kapan-kapan\Nkuajak Nairo ke sana.
Dialogue: 0,0:06:08.47,0:06:11.05,Default,Kinme,0,0,0,,Iya! Aku pamit dulu.
Dialogue: 0,0:06:17.63,0:06:18.86,Default,Hatsuayu,0,0,0,,Ah!
Dialogue: 0,0:06:18.86,0:06:22.86,Default,Kinme,0,0,0,,Ada yang bisa aku bantu,\NHatsuayu-san?
Dialogue: 0,0:06:26.23,0:06:27.37,Default,Hatsuayu,0,0,0,,Ter...
Dialogue: 0,0:06:30.09,0:06:33.37,Default,Hatsuayu,0,0,0,,Terima kasih banyak soal kemarin.
Dialogue: 0,0:06:33.81,0:06:43.88,Default,Hatsuayu,0,0,0,,Maaf, aku hanya ingin melihat\Ncara Kinme melayani pelanggan.
Dialogue: 0,0:06:44.30,0:06:51.39,Default,Hatsuayu,0,0,0,,Aku payah dalam\Nberkomunikasi dengan orang lain.
Dialogue: 0,0:06:53.80,0:07:02.90,Default,Hatsuayu,0,0,0,,Awalnya mengira kerja di balai kota\Nbisa di balik meja saja,
Dialogue: 0,0:07:02.90,0:07:14.91,Default,text,0,0,0,,{\p1\bord0\an8\shad0\c&HF9FBFA&\frz359.8\fad(2441,1)\fscx227\fscy166\pos(422.012,6.667)}m 0 0 l 304.75 0 l 318 286.625 l 0 286.625
Dialogue: 1,0:07:02.90,0:07:14.91,Default,text,0,0,0,,{\an9\shad0\\b1\c&H6D6B70&\3c&HF9FBFA&\fad(2441,1)\fs58.667\pos(617.45,40)}Balai Kota Atami
Dialogue: 1,0:07:02.90,0:07:14.91,Default,text,0,0,0,,{\an7\shad0\fnTimes New Roman\c&H6D6B70&\3c&HF9FBFA&\fs48\fad(2441,1)\pos(121.9,113.333)}Bagian Ekonomi Pariwisata,\NDepartemen Pariwisata dan Konstruksi\NKantor Promosi Pariwisata
Dialogue: 1,0:07:02.90,0:07:14.91,Default,text,0,0,0,,{\an9\shad0\\b1\c&H6D6B70&\3c&HF9FBFA&\fs45.333\fad(2441,1)\pos(813.55,268)}Koordinasi dan Bantuan Lokasi
Dialogue: 0,0:07:02.90,0:07:14.91,Default,text,0,0,0,,{\an9\shad0\\b1\c&H6D6B70&\3c&HF9FBFA&\fs80\fad(2441,1)\pos(662.5,305.333)}Hatsuayu Uka
Dialogue: 1,0:07:03.18,0:07:08.64,Default,Hatsuayu,0,0,0,,tapi malah jadi koordinator lokasi\Ndi Bagian Ekonomi Pariwisata.
Dialogue: 1,0:07:08.64,0:07:14.91,Default,Hatsuayu,0,0,0,,Pekerjaan ini butuh kesigapan\Ndan komunikasi yang hebat.
Dialogue: 0,0:07:15.50,0:07:17.90,Flashback,Voice 1,0,0,0,,Minta izin dari hotel\Nuntuk syuting itu.
Dialogue: 0,0:07:17.90,0:07:19.42,Flashback,Voice 2,0,0,0,,Bisa urus makan siang kru?
Dialogue: 0,0:07:20.42,0:07:23.63,Flashback,Voice 3,0,0,0,,Kami ingin mengubah\Npenginapan aktornya.
Dialogue: 0,0:07:23.63,0:07:25.64,Flashback,Voice 4,0,0,0,,Tolong urus izin penggunaan jalan itu.
Dialogue: 0,0:07:25.64,0:07:27.93,Flashback,Voice 5,0,0,0,,Tahu tempat makan hidden gem gak?
Dialogue: 0,0:07:27.93,0:07:29.98,Flashback,Voice 6,0,0,0,,Kami sedang cari restoran\Nuntuk acara masak.
Dialogue: 0,0:07:29.98,0:07:32.45,Flashback,Voice 7,0,0,0,,Tolong kenalin dengan figuran lokal, dong.
Dialogue: 0,0:07:33.18,0:07:37.45,Default,Hatsuayu,0,0,0,,Aku selalu stres soal itu,
Dialogue: 0,0:07:37.45,0:07:42.94,Default,Hatsuayu,0,0,0,,tapi saat melihat Kinme beraksi\Ndengan komunikasi yang luwes...
Dialogue: 0,0:07:43.33,0:07:46.50,Default,Hatsuayu,0,0,0,,Aku ingin tanya,
Dialogue: 0,0:07:46.50,0:07:51.20,Default,Hatsuayu,0,0,0,,apa rahasianya agar mahir\Ndalam urusan melayani klien?
Dialogue: 0,0:07:52.07,0:08:00.89,Default,Kinme,0,0,0,,Rahasianya?
Dialogue: 0,0:08:00.89,0:08:05.71,Default,Kinme,0,0,0,,Kalau tidak keberatan, bagaimana kalau\Nikut ke pemandian umum malam ini?
Dialogue: 0,0:08:06.03,0:08:06.81,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 1,0:08:07.97,0:08:10.59,Default,text,0,0,0,,{\fs12\shad0\\3c&H5D6669&\c&HF6F2EE&\frz355.2\pos(160.325,145.333)}Buka Pukul 14.00 - 21.00
Dialogue: 0,0:08:07.97,0:08:10.59,Default,text,0,0,0,,{\b1\shad0\fs34.667\frx2\fry12\c&H839BA2&\3c&H4B6771&\pos(46.375,310.667)\frz90.25}Pemandian Air Panas
Dialogue: 0,0:08:07.97,0:08:10.59,Default,text,0,0,0,,{\b1\shad0\fs22.667\frx2\fry12\c&H3E95BA&\3c&HAED7E1&\frz90.25\pos(418.7,113.333)}Depan Stasiun Atami
Dialogue: 0,0:08:07.97,0:08:10.59,Default,text,0,0,0,,{\an8\shad0\pos(748.625,20)\c&H2D4CD0&\3c&HA9E9EA&}Pemandian Air Panas\NDepan Stasiun
Dialogue: 0,0:08:08.78,0:08:10.59,Default,Regular 2,0,0,0,,Dah, Kinme-san. Duluan.
Dialogue: 0,0:08:10.59,0:08:13.26,Default,Kinme,0,0,0,,Ah, selamat malam!
Dialogue: 0,0:08:13.65,0:08:15.64,Default,Regular 3,0,0,0,,Selamat petang, Kinme-san!
Dialogue: 0,0:08:15.64,0:08:19.06,Default,Regular 3,0,0,0,,Hari ini panas sekali!\NBadan rasanya lemas.
Dialogue: 0,0:08:19.06,0:08:23.61,Default,Kinme,0,0,0,,Selamat petang.\NAku juga keringatan seharian.
Dialogue: 0,0:08:23.61,0:08:28.18,Default,Hatsuayu,0,0,0,,Apa Kinme-san sering\Nke pemandian umum?
Dialogue: 0,0:08:28.18,0:08:31.36,Default,Kinme,0,0,0,,Benar. Hampir setiap malam.
Dialogue: 0,0:08:31.36,0:08:35.39,Default,Kinme,0,0,0,,Tempat langgananku di sini\Ndan satu tempat lagi,
Dialogue: 0,0:08:35.39,0:08:37.50,Default,Kinme,0,0,0,,namanya Pemandian Yamada.
Dialogue: 0,0:08:39.68,0:08:44.54,Default,Hatsuayu,0,0,0,,Terakhir aku ke pemandian umum saat masih Tk...
Dialogue: 0,0:08:44.98,0:08:48.26,Default,Hatsuayu,0,0,0,,Tapi aku ke pemandian umum saat mengantar\Norang syuting.
Dialogue: 0,0:08:48.55,0:08:53.82,Default,Kinme,0,0,0,,Kalau sudah biasa berkunjung,\NKamu akan mengenali orang-orangnya,
Dialogue: 0,0:08:53.82,0:08:56.27,Default,Kinme,0,0,0,,dan terbiasa menyapa\Nmaupun berbincang.
Dialogue: 0,0:08:57.53,0:08:59.00,Default,Hatsuayu,0,0,0,,Begitu, ya.
Dialogue: 0,0:08:59.39,0:09:02.65,Default,text,0,0,0,,{\an7\fs29.333\shad0\c&HDCD3D5&\3c&HA98586&\bord2.667}Ini {\c&H461D8A&}mata air panas\N{\c&HDCD3D5&}langsung dari sumbernya.
Dialogue: 0,0:08:59.39,0:09:02.65,Default,text,0,0,0,,{\an9\fs29.333\shad0\c&H8169C0&\3c&HDED4D2&\bord2.667}Mohon jangan tutup\N{\c&HA98586&}aliran air sepenuhnya.
Dialogue: 0,0:08:59.90,0:09:02.65,Default,Housewife 1,0,0,0,,Lihat, ubannya nambah lagi!
Dialogue: 0,0:09:02.65,0:09:04.72,Default,Kid,0,0,0,,Mama terlalu khawatir.
Dialogue: 0,0:09:04.72,0:09:06.40,Default,Housewife 2,0,0,0,,Benar juga.
Dialogue: 0,0:09:06.40,0:09:10.49,Default,Housewife 1,0,0,0,,Oh ya, Yut-chan sedang hamil anak kedua!
Dialogue: 0,0:09:10.49,0:09:11.60,Default,Housewife 2,0,0,0,,Masa?
Dialogue: 0,0:09:11.60,0:09:14.16,Default,Housewife 1,0,0,0,,Iya! Tadi saat menjemput putriku...
Dialogue: 0,0:09:14.42,0:09:20.60,Default,Hatsuayu,0,0,0,,Ramai sekali dan obrolannya sampai terdengar,
Dialogue: 0,0:09:20.60,0:09:24.76,Default,Hatsuayu,0,0,0,,tapi entah kenapa,\Nrasanya menenangkan.
Dialogue: 0,0:09:25.17,0:09:27.67,Default,Kinme,0,0,0,,Benarkah? Syukurlah kalau suka!
Dialogue: 0,0:09:29.29,0:09:33.76,Default,Kinme,0,0,0,,Sebenarnya, aku rasa\Ntidak ada rahasia khusus.
Dialogue: 0,0:09:33.76,0:09:34.68,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 0,0:09:36.15,0:09:41.13,Default,Kinme,0,0,0,,Memang butuh keahlian untuk mencuci,
Dialogue: 0,0:09:41.13,0:09:42.67,Default,Kinme,0,0,0,,tapi entahlah,
Dialogue: 0,0:09:43.34,0:09:49.08,Default,Kinme,0,0,0,,aku melakukannya karena senang\Nmelihat pelanggan puas.
Dialogue: 0,0:09:50.83,0:09:58.08,Default,Kinme,0,0,0,,Mungkin lebih tepatnya, aku sangat suka\Nkota ini dan orang-orangnya.
Dialogue: 0,0:10:01.08,0:10:05.35,Default,Hatsuayu,0,0,0,,Suka kotanya... ingin pelanggan puas...
Dialogue: 0,0:10:07.07,0:10:09.90,Default,Kinme,0,0,0,,Agak sulit diungkapkan dengan kata-kata,
Dialogue: 0,0:10:09.90,0:10:14.09,Default,Kinme,0,0,0,,tapi itulah arti pekerjaan\Nini bagiku.
Dialogue: 0,0:10:14.38,0:10:17.03,Default,Hatsuayu,0,0,0,,Aku mengerti.
Dialogue: 0,0:10:17.97,0:10:19.72,Default,Kinme,0,0,0,,Kamu pingsan!
Dialogue: 0,0:10:19.72,0:10:23.52,Default,Hatsuayu,0,0,0,,Tapi ini sangat berharga.
Dialogue: 0,0:10:23.52,0:10:24.79,Default,Kinme,0,0,0,,Tunggu...
Dialogue: 0,0:10:24.79,0:10:27.79,Default,Kinme,0,0,0,,Hatsuayu-san!\NAyo cepat keluar!
Dialogue: 0,0:10:33.87,0:10:36.71,Italics,Kinme (M),0,0,0,,Kemarin seru, ya.
Dialogue: 0,0:10:37.90,0:10:43.18,Flashback,Hatsuayu,0,0,0,,Aku akan mulai pergi\Nke pemandian umum tiap hari
Dialogue: 0,0:10:43.18,0:10:45.10,Flashback,Hatsuayu,0,0,0,,{\t(1589,2298,\1c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}untuk melatih kemampuan sosial.
Dialogue: 0,0:10:46.39,0:10:48.35,Italics,Kinme (M),0,0,0,,Semangat buat dia, deh.
Dialogue: 0,0:10:53.42,0:10:56.93,Default,Kinme,0,0,0,,Wah! Sedang ada syuting?
Dialogue: 0,0:10:57.22,0:10:58.92,Default,Director,0,0,0,,Nah, oke!
Dialogue: 0,0:11:02.42,0:11:04.37,Default,Hatsuayu,0,0,0,,Senang bisa membantu.
Dialogue: 0,0:11:08.69,0:11:11.65,Default,Kinme,0,0,0,,Sampai jumpa di pemandian!
Dialogue: 0,0:11:41.47,0:11:46.98,Default,Kinme,0,0,0,,Wah, aku belum pernah\Nlihat kota dari sini.
Dialogue: 0,0:11:53.02,0:11:55.49,Flashback,Kinme,0,0,0,,Halo, ini Laundry Kinme.
Dialogue: 0,0:11:55.49,0:12:02.07,Flashback Italics,Hatsuayu,0,0,0,,Kinme-san, maukah\Nmenjadi model pemotretan?
Dialogue: 0,0:12:02.07,0:12:02.99,Flashback,Kinme,0,0,0,,Eh?
Dialogue: 0,0:12:02.99,0:12:07.00,Default,text,0,0,0,,{\an7\shad0\fnTimes New Roman\c&H6D6B70&\3c&HFEFFFF&\fs26\frz13.65\fax-0.26\pos(127.2,238.667)}Bagian Ekonomi Pariwisata
Dialogue: 0,0:12:02.99,0:12:07.00,Default,text,0,0,0,,{\an7\shad0\fnTimes New Roman\c&H6D6B70&\3c&HFEFFFF&\fs16\frz13.65\fax-0.26\pos(418.7,109.333)}\h\hKantor Promosi Pariwisata / Kantor Pengembangan Industri\N\hKantor Strategi Promosi Media\NKantor Pertanian, Kehutanan dan Perikanan / Komite Pertanian
Dialogue: 0,0:12:02.99,0:12:07.00,Flashback,Hatsuayu,0,0,0,,Koran lokal menerbitkan buletin,\Ndan akan membuat artikel soal
Dialogue: 0,0:12:07.00,0:12:12.25,Flashback,Hatsuayu,0,0,0,,"Wisata Sehari Gadis-Gadis."
Dialogue: 0,0:12:12.25,0:12:17.93,Flashback,Hatsuayu,0,0,0,,Pihak koran mencari wanita pekerja lokal\Nuntuk dijadikan model.
Dialogue: 0,0:12:17.93,0:12:20.51,Flashback,Hatsuayu,0,0,0,,untuk pemotretan.
Dialogue: 0,0:12:20.93,0:12:22.25,Flashback,Kinme,0,0,0,,Aku mengerti.
Dialogue: 0,0:12:22.25,0:12:28.15,Flashback Italics,Hatsuayu,0,0,0,,Jadi, salah satunya adalah aku,
Dialogue: 0,0:12:28.15,0:12:31.00,Flashback Italics,Hatsuayu,0,0,0,,tapi mereka butuh satu orang lagi.
Dialogue: 0,0:12:31.00,0:12:32.02,Flashback Italics,Hatsuayu,0,0,0,,Jadi,
Dialogue: 0,0:12:32.02,0:12:35.00,Flashback,Hatsuayu,0,0,0,,aku ingin mengajakmu.
Dialogue: 0,0:12:35.32,0:12:38.78,Flashback,Kinme,0,0,0,,Eh? Aku?
Dialogue: 0,0:12:41.03,0:12:45.54,Flashback,Kinme,0,0,0,,Tapi aku sama sekali\Ntidak bisa jadi model
Dialogue: 0,0:12:45.54,0:12:50.17,Flashback,Hatsuayu,0,0,0,,Maaf mendadak, tapi...
Dialogue: 0,0:12:50.17,0:12:53.18,Flashback Italics,Hatsuayu,0,0,0,,Ada honornya kok,
Dialogue: 0,0:12:53.18,0:12:59.55,Flashback Italics,Hatsuayu,0,0,0,,dan mereka akan memasang iklan\Nlaundry Kinme secara gratis.
Dialogue: 0,0:13:01.30,0:13:05.72,Default,text,0,0,0,,{\an1\shad0\c&H7E94BB&\3c&HFCFDFD&\b1\t(3066,4318,\c&H000000&\3c&H000000&\4c&H000000&)}Musim gugur tiba...\N{\c&H84B095&\t(3066,4318,\c&H000000&\3c&H000000&\4c&H000000&)}Publikasi...
Dialogue: 0,0:13:01.30,0:13:05.72,Default,text,0,0,0,,{\an3\shad0\c&HA682AB&\3c&HFCFDFD&\b1\t(3066,4318,\c&H000000&\3c&H000000&\4c&H000000&)}Iklan...\N{\c&H999259&\t(3066,4318,\c&H000000&\3c&H000000&\4c&H000000&)}Gratis...
Dialogue: 0,0:13:10.38,0:13:15.74,Default,Hatsuayu,0,0,0,,E-Etto... aku jelaskan\Njadwal hari ini, ya?
Dialogue: 0,0:13:15.74,0:13:16.65,Default,Kinme,0,0,0,,Baiklah.
Dialogue: 0,0:13:16.65,0:13:20.43,Default,Hatsuayu,0,0,0,,Fotografer sudah pergi duluan\Nuntuk memotret pemandangan.
Dialogue: 0,0:13:20.43,0:13:23.16,Default,Hatsuayu,0,0,0,,Kita akan menyusul mereka,
Dialogue: 0,0:13:23.16,0:13:28.66,Default,Hatsuayu,0,0,0,,lalu memotret di sekitar pintu masuk\Npulau dan area restoran.
Dialogue: 0,0:13:28.66,0:13:31.71,Default,Hatsuayu,0,0,0,,Setelah itu, kita ke resor
Dialogue: 0,0:13:31.71,0:13:35.46,Default,Hatsuayu,0,0,0,,untuk berfoto di kafe\Ndan taman bermain.
Dialogue: 0,0:13:35.46,0:13:38.17,Default,Hatsuayu,0,0,0,,Lalu kembali naik feri terakhir.
Dialogue: 0,0:13:38.50,0:13:41.72,Default,Hatsuayu,0,0,0,,Begitu rencananya.
Dialogue: 0,0:13:41.72,0:13:43.21,Default,Kinme,0,0,0,,Aku mengerti.
Dialogue: 0,0:13:43.21,0:13:45.80,Default,Kinme,0,0,0,,Ternyata pulaunya dekat, ya?
Dialogue: 0,0:13:45.80,0:13:49.36,Default,Hatsuayu,0,0,0,,Iya! Hanya 23 menit saja,
Dialogue: 0,0:13:49.36,0:13:53.27,Default,Hatsuayu,0,0,0,,pulau terdekat dari wilayah\Nmetropolitan Tokyo.
Dialogue: 0,0:13:53.27,0:13:56.53,Default,Kinme,0,0,0,,Kamu sangat tahu banyak hal.
Dialogue: 0,0:13:56.53,0:14:00.19,Default,Hatsuayu,0,0,0,,sEh? Kan aku orang sini.
Dialogue: 0,0:14:00.60,0:14:03.45,Default,Hatsuayu,0,0,0,,Oh, kita sudah sampai.
Dialogue: 0,0:14:10.45,0:14:14.46,Default,text,0,0,0,,{\an8\fs29.333\b1\c&H7CE4F7&\4c&H234250&\3c&H698597&}Selamat datang di {\fs40}Hatsushima
Dialogue: 0,0:14:24.01,0:14:27.47,Default,text,0,0,0,,{\an8\fs29.333\b1\c&H7CE4F7&\4c&H234250&\3c&H698597&\fad(395,1)\move(424,22.667,424,106.667)}Selamat datang di {\fs40}Hatsushima
Dialogue: 0,0:14:34.75,0:14:36.38,Default,Hatsuayu,0,0,0,,Maaf sudah menunggu.
Dialogue: 0,0:14:36.38,0:14:38.24,Default,Kinme,0,0,0,,Mohon kerja samanya.
Dialogue: 0,0:14:39.53,0:14:43.11,Default,Cameraman,0,0,0,,Ayo kita ambil foto\Nsaat kalian baru sampai.
Dialogue: 0,0:14:43.63,0:14:47.11,Default,Cameraman,0,0,0,,Bawakan suasana "wisata santai\Ngadis-gadis," ya?
Dialogue: 0,0:14:47.11,0:14:49.66,Default,Cameraman,0,0,0,,Oh, helmnya dilepas saja.
Dialogue: 0,0:14:49.83,0:14:52.62,Default,text,0,0,0,,{\an8\fs29.333\b1\c&H7CE4F7&\4c&H234250&\3c&H698597&\pos(470.375,106.667)}Selamat datang di {\fs40}Hatsushima
Dialogue: 0,0:14:52.95,0:14:56.63,Default,Cameraman,0,0,0,,Mantap. Posenya juga bagus!
Dialogue: 0,0:14:57.32,0:15:02.42,Default,Hatsuayu,0,0,0,,Eh? Kinme-san,\Nsepertinya sudah terbiasa.
Dialogue: 0,0:15:02.42,0:15:07.13,Default,Kinme,0,0,0,,Ah, akhir-akhir ini\Naku sering latihan
Dialogue: 0,0:15:07.13,0:15:09.22,Default,Kinme,0,0,0,,bersama anak SD.
Dialogue: 0,0:15:09.22,0:15:10.14,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 0,0:15:10.48,0:15:13.38,Default,Editor,0,0,0,,Lanjut ke area\Nrestoran sekarang, ya.
Dialogue: 0,0:15:13.38,0:15:15.70,Default,Editor,0,0,0,,Kalian belum makan siang, 'kan?
Dialogue: 0,0:15:15.70,0:15:16.56,Default,Kinme,0,0,0,,Eh?
Dialogue: 0,0:15:17.15,0:15:20.15,Default,text,0,0,0,,{\b1\shad0\frz355\move(7.95,100,49.025,100,0,2977)\fs29.333\c&H5E4F66&\3c&HC3A3E6&}Makan Siang
Dialogue: 0,0:15:22.76,0:15:27.85,Default,Kinme,0,0,0,,A-Apa kami boleh makan ini?
Dialogue: 0,0:15:27.85,0:15:28.91,Default,Editor,0,0,0,,Tentu saja!
Dialogue: 0,0:15:29.26,0:15:31.66,Default,Editor,0,0,0,,Kami berdua akan makan nanti.
Dialogue: 0,0:15:31.66,0:15:36.14,Default,Hatsuayu,0,0,0,,Berkilau! Semuanya berkilauan!
Dialogue: 0,0:15:36.14,0:15:39.92,Default,Hatsuayu,0,0,0,,Padahal aku orang lokal,\Ntapi jarang makan mewah begini!
Dialogue: 0,0:15:39.92,0:15:41.31,Default,Kinme,0,0,0,,Iya.
Dialogue: 0,0:15:42.87,0:15:45.19,Default,Kinme,0,0,0,,Kami makan, ya.
Dialogue: 0,0:15:45.19,0:15:47.51,Default,Cameraman,0,0,0,,Nikmati makannya, ya?
Dialogue: 0,0:15:59.94,0:16:04.46,Italics,Kinme (M),0,0,0,,Ah! Sashiminya sangat segar!
Dialogue: 0,0:16:04.46,0:16:07.88,Italics,Kinme (M),0,0,0,,Teksturnya kenyal dan\Nrasa lautnya terasa sekali!
Dialogue: 0,0:16:08.95,0:16:11.67,Default,Hatsuayu,0,0,0,,Enak sekali!
Dialogue: 0,0:16:11.67,0:16:15.04,Default,Hatsuayu,0,0,0,,Sudah lama aku tidak\Nmakan enak begini!
Dialogue: 0,0:16:16.96,0:16:21.07,Italics,Kinme (M),0,0,0,,Memangnya biasanya Hatsuayu-san makan apa?
Dialogue: 0,0:16:45.82,0:16:50.03,Default,Kinme,0,0,0,,Aku harus pakai ini? Tadi tidak dibilang!
Dialogue: 0,0:16:50.03,0:16:52.84,Default,Hatsuayu,0,0,0,,Maaf, Kinme-san.
Dialogue: 0,0:16:52.84,0:16:56.40,Default,Hatsuayu,0,0,0,,Takutnya bakal ditolak jika diberitahu.
Dialogue: 0,0:16:56.40,0:16:58.62,Default,Kinme,0,0,0,,Duh.
Dialogue: 0,0:17:02.27,0:17:06.76,Default,Cameraman,0,0,0,,Posturmu bagus sekali!\NAyo lanjut pemotretannya.
Dialogue: 0,0:17:07.07,0:17:08.08,Default,Kinme,0,0,0,,Mo...
Dialogue: 0,0:17:08.76,0:17:12.92,Default,Kinme,0,0,0,,Mohon kerja samanya.
Dialogue: 0,0:17:39.33,0:17:42.17,Default,Kinme,0,0,0,,Ada adegan mandi, ya.
Dialogue: 0,0:17:42.43,0:17:45.56,Default,Hatsuayu,0,0,0,,Mohon maaf.
Dialogue: 0,0:17:48.67,0:17:50.47,Default,Cameraman,0,0,0,,Oh! Begitu saja!
Dialogue: 0,0:17:51.56,0:17:52.95,Italics,Cameraman (M),0,0,0,,Ekspresi yang manis.
Dialogue: 0,0:17:55.41,0:17:58.18,Default,Cameraman,0,0,0,,Selesai! Terima kasih kalian berdua.
Dialogue: 0,0:17:59.38,0:18:01.10,Default,Hatsuayu,0,0,0,,Sudah selesai.
Dialogue: 0,0:18:01.95,0:18:02.82,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 0,0:18:10.82,0:18:13.32,Default,text,0,0,0,,{\an8\\shad0\b1\frz8.119\fs34.667\shad1.333\c&HD9FDFE&\move(376.3,42.667,376.3,94.667,19,2480)\3c&H958C3B&\4c&H2B6190&}Supermarket Hatsushima
Dialogue: 0,0:18:14.92,0:18:18.83,Default,Hatsuayu,0,0,0,,Eh? Kinme-san ke mana lagi?
Dialogue: 0,0:18:19.26,0:18:21.55,Default,Hatsuayu,0,0,0,,Tadi ada di sini.
Dialogue: 0,0:18:21.55,0:18:24.23,Default,Cameraman,0,0,0,,Sebentar lagi kapal terakhir berangkat, loh.
Dialogue: 0,0:18:24.23,0:18:26.65,Default,Hatsuayu,0,0,0,,Aku cari dulu.
Dialogue: 0,0:18:31.34,0:18:35.34,Default,text,0,0,0,,{\an8\shad0\fs26.667\c&H13497B&\3c&H4363A5&\move(665.15,80,715.5,80,0,3982)}Penginapan
Dialogue: 0,0:18:35.34,0:18:39.35,Default,text,0,0,0,,{\an8\shad0\fs40\c&H9FB5CF&\3c&H4363A5&\move(406.775,26.667,483.625,26.667,24,3982)\b1}Penginapan
Dialogue: 0,0:18:35.34,0:18:39.35,Default,text,0,0,0,,{\an8\shad0\fs46.667\c&H9FB5CF&\3c&H32344A&\move(410.75,382.667,483.625,382.667,24,3982)\b1}Kiki
Dialogue: 0,0:19:12.20,0:19:14.63,Default,Hatsuayu,0,0,0,,Dia ke mana, ya?
Dialogue: 0,0:19:18.12,0:19:19.39,Default,Hatsuayu,0,0,0,,Oh, itu dia!
Dialogue: 0,0:19:20.30,0:19:21.14,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 0,0:19:30.43,0:19:32.90,Default,Kinme,0,0,0,,Oh, Hatsuayu-san.
Dialogue: 0,0:19:33.29,0:19:36.65,Default,Hatsuayu,0,0,0,,A-Anu, kapalnya segera berangkat!
Dialogue: 0,0:19:36.65,0:19:39.12,Default,Kinme,0,0,0,,Oh, maaf!
Dialogue: 0,0:19:39.66,0:19:44.68,Default,Kinme,0,0,0,,Maaf, gara-gara aku, kamu harus ikuit berlari juga!
Dialogue: 0,0:19:45.16,0:19:46.82,Default,Hatsuayu,0,0,0,,Tidak apa-apa!
Dialogue: 0,0:19:46.82,0:19:48.67,Default,Kinme,0,0,0,,Kita akan keburu, 'kan?
Dialogue: 0,0:19:48.67,0:19:52.17,Default,text,0,0,0,,{\an8\fs29.333\b1\c&H75C0F0&\4c&H002C6E&\3c&H4A88D3&}Selamat datang di {\fs40}Hatsushima
Dialogue: 0,0:19:48.67,0:19:51.24,Default,Hatsuayu,0,0,0,,Iya! Harus keburu.
Dialogue: 0,0:19:56.58,0:19:58.34,Default,Cameraman,0,0,0,,Itu mereka!
Dialogue: 0,0:19:58.34,0:19:59.68,Default,Cameraman,0,0,0,,Hei!
Dialogue: 0,0:20:09.98,0:20:14.19,Default,Kinme,0,0,0,,Ah, aku lupa beli oleh-oleh.
Dialogue: 0,0:20:15.53,0:20:19.01,Default,Kinme,0,0,0,,Kukira aku punya banyak waktu luang.
Dialogue: 0,0:20:30.46,0:20:32.77,Default,Hatsuayu,0,0,0,,Anu, Kinme-san?
Dialogue: 0,0:20:32.77,0:20:33.58,Default,Kinme,0,0,0,,Iya?
Dialogue: 0,0:20:33.58,0:20:39.23,Default,Hatsuayu,0,0,0,,Anu, apa kamu pernah\Nke Hatsushima sebelumnya?
Dialogue: 0,0:20:39.23,0:20:39.97,Default,Kinme,0,0,0,,Eh?
Dialogue: 0,0:20:40.45,0:20:42.88,Default,Hatsuayu,0,0,0,,Maaf kalau aku salah,
Dialogue: 0,0:20:42.88,0:20:48.48,Default,Hatsuayu,0,0,0,,tapi tadi Kinme tampak\Nseperti sedang bernostalgia.
Dialogue: 0,0:20:50.56,0:20:53.23,Default,Kinme,0,0,0,,Aku juga tidak tahu.
Dialogue: 0,0:20:53.54,0:20:54.57,Default,Hatsuayu,0,0,0,,Eh?
Dialogue: 0,0:20:54.57,0:21:00.24,Default,Kinme,0,0,0,,Aku tidak ingat apa pun\Nsebelum dua tahun lalu.
Dialogue: 0,0:21:04.96,0:21:06.49,Default,Kinme,0,0,0,,Hari ini menyenangkan.
Dialogue: 0,0:21:08.01,0:21:11.22,Default,Hatsuayu,0,0,0,,Iya! Meski ini pekerjaanku, sih.
Dialogue: 0,0:21:11.22,0:21:14.38,Default,Hatsuayu,0,0,0,,Aku sangat menikmatinya.
Dialogue: 0,0:21:14.38,0:21:19.02,Default,Kinme,0,0,0,,Tapi kebetulan hari ini aku libur,\Njadi waktunya pas sekali.
Dialogue: 0,0:21:19.02,0:21:20.55,Default,Kinme,0,0,0,,Terima kasih sudah mengajak!
Dialogue: 0,0:21:20.55,0:21:23.90,Default,Hatsuayu,0,0,0,,Sama-sama. Maaf mengganggu hari liburmu.
Dialogue: 0,0:21:25.88,0:21:30.63,Default,Kinme,0,0,0,,Aku juga bingung harus melakukan\Napa di hari libur.
Dialogue: 0,0:21:30.63,0:21:33.20,Default,Kinme,0,0,0,,Kadang malah tidak melakukan apa pun.
Dialogue: 0,0:21:34.94,0:21:40.78,Default,Hatsuayu,0,0,0,,Jika sedang luang, silakan hubungi aku kapan saja.
Dialogue: 0,0:21:41.12,0:21:43.34,Default,Kinme,0,0,0,,Eh? Boleh, nih?
Dialogue: 0,0:21:43.34,0:21:48.91,Default,Hatsuayu,0,0,0,,Tentu saja! Aku punya banyak saran.\NLagipula...
Dialogue: 0,0:21:49.47,0:21:52.61,Default,Hatsuayu,0,0,0,,Aku kan, kerja di bagian pariwisata.
Dialogue: 0,0:17:08.52,0:17:20.52,Default,Kinme,0,0,0,,{\an7\fs24}Dukung kami tetap meriils anime melalui \Nhttps://huntersekai.fansub.my.id/
Dialogue: 0,0:21:54.60,0:21:55.84,Default,Kinme,0,0,0,,Aku menantikannya!
